@page
@model EmailModel
@{
    ViewData["Title"] = "Manage Email";
    ViewData["ActivePage"] = ManageNavPages.Email;
}

<h5 class="fw-bold mb-3"><i class="bi bi-envelope me-2"></i>Email Settings</h5>
<partial name="_StatusMessage" for="StatusMessage" />
<form id="email-form" method="post">
    <div asp-validation-summary="All" class="text-danger" role="alert"></div>
    <div class="row">
        <div class="col-md-8">
            @if (Model.IsEmailConfirmed)
            {
                <div class="form-floating mb-3 input-group">
                    <input asp-for="Email" class="form-control" placeholder="Please enter your email." disabled />
                    <span class="input-group-text text-success"><i class="bi bi-check-circle-fill"></i></span>
                    <label asp-for="Email" class="form-label"><i class="bi bi-envelope-check me-1"></i>Current Email</label>
                </div>
            }
            else
            {
                <div class="form-floating mb-3">
                    <input asp-for="Email" class="form-control" placeholder="Please enter your email." disabled />
                    <label asp-for="Email" class="form-label"><i class="bi bi-envelope me-1"></i>Current Email</label>
                </div>
                <button id="email-verification" type="submit" asp-page-handler="SendVerificationEmail" class="btn btn-outline-primary btn-sm mb-3">
                    <i class="bi bi-send me-1"></i>Send verification email
                </button>
            }
            <div class="form-floating mb-3">
                <input asp-for="Input.NewEmail" class="form-control" autocomplete="email" aria-required="true" placeholder="Please enter new email." />
                <label asp-for="Input.NewEmail" class="form-label"><i class="bi bi-envelope-plus me-1"></i>New Email</label>
                <span asp-validation-for="Input.NewEmail" class="text-danger"></span>
            </div>
            <button id="change-email-button" type="submit" asp-page-handler="ChangeEmail" class="btn btn-primary">
                <i class="bi bi-check-lg me-1"></i>Change Email
            </button>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
