@page
@model DeletePersonalDataModel
@{
    ViewData["Title"] = "Delete Personal Data";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<h5 class="fw-bold mb-3"><i class="bi bi-trash text-danger me-2"></i>Delete Personal Data</h5>

<div class="row">
    <div class="col-md-8">
        <div class="alert alert-danger border-0" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <strong>Deleting this data will permanently remove your account, and this cannot be recovered.</strong>
        </div>
        <form id="delete-user" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            @if (Model.RequirePassword)
            {
                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="Please enter your password." />
                    <label asp-for="Input.Password" class="form-label"><i class="bi bi-lock me-1"></i>Password</label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>
            }
            <button class="btn btn-danger" type="submit">
                <i class="bi bi-trash me-1"></i>Delete data and close my account
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
