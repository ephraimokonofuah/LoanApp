@page
@model PersonalDataModel
@{
    ViewData["Title"] = "Personal Data";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<h5 class="fw-bold mb-3"><i class="bi bi-database me-2"></i>Personal Data</h5>

<div class="row">
    <div class="col-md-8">
        <p class="text-muted">Your account contains personal data that you have given us. This page allows you to download or delete that data.</p>
        <div class="alert alert-warning border-0" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>
            <strong>Deleting this data will permanently remove your account, and this cannot be recovered.</strong>
        </div>
        <div class="d-flex gap-2">
            <form id="download-data" asp-page="DownloadPersonalData" method="post">
                <button class="btn btn-primary" type="submit">
                    <i class="bi bi-download me-1"></i>Download Data
                </button>
            </form>
            <a id="delete" asp-page="DeletePersonalData" class="btn btn-outline-danger">
                <i class="bi bi-trash me-1"></i>Delete Account
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
