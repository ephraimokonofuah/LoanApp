@page
@model AccessDeniedModel
@{
    ViewData["Title"] = "Access denied";
}

<div class="row justify-content-center mt-5">
    <div class="col-lg-5 col-md-7">
        <div class="text-center mb-4">
            <i class="bi bi-shield-x text-danger" style="font-size: 3rem;"></i>
            <h3 class="mt-2 fw-bold">Access Denied</h3>
            <p class="text-muted">You don't have permission to access this resource</p>
        </div>
        <div class="card shadow-sm border-0">
            <div class="card-body p-4 text-center">
                <p class="mb-3">Please contact an administrator if you believe this is an error.</p>
                <a href="/" class="btn btn-primary">
                    <i class="bi bi-house me-2"></i>Go to Home
                </a>
            </div>
        </div>
    </div>
</div>
