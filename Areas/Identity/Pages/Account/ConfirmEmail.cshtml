@page
@model ConfirmEmailModel
@{
    ViewData["Title"] = "Email Confirmed";
}

<div class="row justify-content-center mt-5">
    <div class="col-lg-5 col-md-7">
        @if (Model.StatusMessage != null && Model.StatusMessage.Contains("Thank you"))
        {
            <div class="text-center mb-4">
                <div class="mx-auto d-flex align-items-center justify-content-center rounded-circle bg-success bg-opacity-10" style="width:80px; height:80px;">
                    <i class="bi bi-check-circle text-success" style="font-size: 2.5rem;"></i>
                </div>
                <h3 class="mt-3 fw-bold text-success">Email Confirmed!</h3>
                <p class="text-muted">Your email address has been verified successfully</p>
            </div>
            <div class="card shadow-sm border-0">
                <div class="card-body p-4 text-center">
                    <p class="fs-5 mb-3">Your account is now fully activated. You can log in and start using LoanApp.</p>
                    <a asp-page="./Login" class="btn btn-primary btn-lg">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Log In Now
                    </a>
                </div>
            </div>
        }
        else
        {
            <div class="text-center mb-4">
                <div class="mx-auto d-flex align-items-center justify-content-center rounded-circle bg-danger bg-opacity-10" style="width:80px; height:80px;">
                    <i class="bi bi-x-circle text-danger" style="font-size: 2.5rem;"></i>
                </div>
                <h3 class="mt-3 fw-bold text-danger">Confirmation Failed</h3>
                <p class="text-muted">We couldn't verify your email address</p>
            </div>
            <div class="card shadow-sm border-0">
                <div class="card-body p-4 text-center">
                    <p class="mb-3">The confirmation link may have expired or is invalid. Please try registering again or contact support.</p>
                    <a asp-page="./Register" class="btn btn-primary">
                        <i class="bi bi-person-plus me-2"></i>Register Again
                    </a>
                </div>
            </div>
        }
    </div>
</div>
