@page
@model ForgotPasswordConfirmation
@{
    ViewData["Title"] = "Check Your Email";
}

<div class="row justify-content-center mt-5">
    <div class="col-lg-5 col-md-7">
        <div class="text-center mb-4">
            <div class="mx-auto d-flex align-items-center justify-content-center rounded-circle bg-warning bg-opacity-10" style="width:80px; height:80px;">
                <i class="bi bi-envelope-paper text-warning" style="font-size: 2.5rem;"></i>
            </div>
            <h3 class="mt-3 fw-bold">Check Your Email</h3>
            <p class="text-muted">We've sent you a password reset link</p>
        </div>
        <div class="card shadow-sm border-0">
            <div class="card-body p-4 text-center">
                <div class="text-start bg-light rounded p-3 mb-3">
                    <p class="fw-semibold mb-2"><i class="bi bi-info-circle text-primary me-2"></i>What to do next:</p>
                    <ol class="mb-0 ps-3" style="line-height: 2;">
                        <li>Open your email inbox</li>
                        <li>Find the email from <strong>LoanApp</strong></li>
                        <li>Click the <strong>"Reset My Password"</strong> button</li>
                        <li>Create a new secure password</li>
                    </ol>
                </div>
                <div class="alert alert-warning border-0 py-2 px-3 mb-3">
                    <small><i class="bi bi-exclamation-triangle me-1"></i>Don't see the email? Check your <strong>spam</strong> or <strong>junk</strong> folder.</small>
                </div>
                <div class="alert alert-light border py-2 px-3 mb-3">
                    <small><i class="bi bi-clock me-1"></i>The reset link will expire in <strong>24 hours</strong>.</small>
                </div>
            </div>
        </div>
        <div class="text-center mt-3">
            <a asp-page="./Login" class="text-decoration-none fw-semibold"><i class="bi bi-arrow-left me-1"></i>Back to login</a>
        </div>
    </div>
</div>
</div>
