@page
@model RegisterConfirmationModel
@{
    ViewData["Title"] = "Check Your Email";
}

<div class="row justify-content-center mt-5">
    <div class="col-lg-5 col-md-7">
        <div class="text-center mb-4">
            <div class="mx-auto d-flex align-items-center justify-content-center rounded-circle bg-primary bg-opacity-10" style="width:80px; height:80px;">
                <i class="bi bi-envelope-paper text-primary" style="font-size: 2.5rem;"></i>
            </div>
            <h3 class="mt-3 fw-bold">Check Your Email</h3>
            <p class="text-muted">We've sent a confirmation link to your inbox</p>
        </div>
        <div class="card shadow-sm border-0">
            <div class="card-body p-4 text-center">
                @if (Model.DisplayConfirmAccountLink)
                {
                    <p>This app does not currently have a real email sender registered.</p>
                    <a id="confirm-link" href="@Model.EmailConfirmationUrl" class="btn btn-primary">
                        <i class="bi bi-check-circle me-2"></i>Click here to confirm your account
                    </a>
                }
                else
                {
                    <div class="mb-3">
                        <p class="fs-5 mb-2">A confirmation email has been sent to:</p>
                        <p class="fw-bold text-primary fs-5 mb-0">@Model.Email</p>
                    </div>
                    <hr class="my-3">
                    <div class="text-start bg-light rounded p-3 mb-3">
                        <p class="fw-semibold mb-2"><i class="bi bi-info-circle text-primary me-2"></i>What to do next:</p>
                        <ol class="mb-0 ps-3" style="line-height: 2;">
                            <li>Open your email inbox</li>
                            <li>Find the email from <strong>LoanApp</strong></li>
                            <li>Click the <strong>"Confirm Email Address"</strong> button</li>
                            <li>Return here and <a asp-page="./Login" class="text-decoration-none fw-semibold">log in</a></li>
                        </ol>
                    </div>
                    <div class="alert alert-warning border-0 py-2 px-3 mb-3">
                        <small><i class="bi bi-exclamation-triangle me-1"></i>Don't see the email? Check your <strong>spam</strong> or <strong>junk</strong> folder.</small>
                    </div>
                    <a asp-page="./Login" class="btn btn-primary">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Go to Login
                    </a>
                }
            </div>
        </div>
    </div>
</div>
