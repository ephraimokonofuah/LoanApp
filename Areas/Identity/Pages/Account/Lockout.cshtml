@page
@model LockoutModel
@{
    ViewData["Title"] = "Locked out";
}

<div class="row justify-content-center mt-5">
    <div class="col-lg-5 col-md-7">
        <div class="text-center mb-4">
            <i class="bi bi-lock-fill text-warning" style="font-size: 3rem;"></i>
            <h3 class="mt-2 fw-bold">Account Locked</h3>
            <p class="text-muted">Too many failed login attempts</p>
        </div>
        <div class="card shadow-sm border-0">
            <div class="card-body p-4 text-center">
                <p class="mb-3">This account has been locked out due to multiple failed login attempts. Please try again later.</p>
                <a asp-page="./Login" class="btn btn-primary">
                    <i class="bi bi-arrow-left me-2"></i>Back to Login
                </a>
            </div>
        </div>
    </div>
</div>
