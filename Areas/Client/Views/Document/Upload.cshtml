@model int

@{
    ViewData["Title"] = "Upload Documents";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8">
            <h2>Upload Supporting Documents</h2>
            <p class="text-muted">Please upload all required documents to support your loan application</p>
            
            <form id="uploadForm" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" id="loanApplicationId" value="@Model" />
                
                <div class="mb-3">
                    <label for="documentType" class="form-label">Document Type <span class="text-danger">*</span></label>
                    <select id="documentType" name="documentType" class="form-control" required>
                        <option value="">Select Document Type</option>
                        <option value="ProofOfIncome">Proof of Income</option>
                        <option value="IdentityProof">Identity Proof</option>
                        <option value="AddressProof">Address Proof</option>
                        <option value="BankStatement">Bank Statement</option>
                        <option value="CreditReport">Credit Report</option>
                        <option value="EmploymentProof">Employment Proof</option>
                        <option value="TaxReturn">Tax Return</option>
                        <option value="Other">Other</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label for="file" class="form-label">Choose File <span class="text-danger">*</span></label>
                    <input type="file" id="file" name="file" class="form-control" accept=".pdf,.jpg,.jpeg,.png,.doc,.docx" required />
                    <small class="text-muted d-block mt-2">
                        <strong>Allowed formats:</strong> PDF, JPG, PNG, DOC, DOCX <br/>
                        <strong>Max file size:</strong> 5MB
                    </small>
                </div>

                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-cloud-upload"></i> Upload Document
                </button>
            </form>

            <div id="uploadMessage"></div>
        </div>
    </div>

    <div class="row mt-5">
        <div class="col-md-8">
            <h4>Uploaded Documents</h4>
            <div class="table-responsive">
                <table class="table table-striped" id="documentsTable">
                    <thead class="table-light">
                        <tr>
                            <th>Document Type</th>
                            <th>File Name</th>
                            <th>Upload Date</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td colspan="5" class="text-center text-muted">Loading...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Document Viewer Modal -->
<div class="modal fade" id="viewerModal" tabindex="-1" aria-labelledby="viewerModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="viewerModalLabel">View Document</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="viewerContent">
                <!-- Content will be inserted here -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const loanApplicationId = document.getElementById('loanApplicationId').value;

        // Load documents on page load
        loadDocuments();

        // Form submission
        document.getElementById('uploadForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const formData = new FormData();
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            
            formData.append('loanApplicationId', loanApplicationId);
            formData.append('file', document.getElementById('file').files[0]);
            formData.append('documentType', document.getElementById('documentType').value);
            formData.append('__RequestVerificationToken', token);

            try {
                const response = await fetch('/Client/Document/Upload', {
                    method: 'POST',
                    body: formData
                });

                const data = await response.json();
                
                if (data.success) {
                    const messageDiv = document.getElementById('uploadMessage');
                    messageDiv.innerHTML = '<div class="alert alert-success alert-dismissible fade show">Document uploaded successfully<button class="btn-close" data-bs-dismiss="alert"></button></div>';
                    document.getElementById('uploadForm').reset();
                    loadDocuments();
                    setTimeout(() => {
                        messageDiv.innerHTML = '';
                    }, 5000);
                } else {
                    document.getElementById('uploadMessage').innerHTML = `<div class="alert alert-danger alert-dismissible fade show">${data.message || 'Error uploading document'}<button class="btn-close" data-bs-dismiss="alert"></button></div>`;
                }
            } catch (error) {
                console.error('Error:', error);
                document.getElementById('uploadMessage').innerHTML = '<div class="alert alert-danger alert-dismissible fade show">Error uploading document<button class="btn-close" data-bs-dismiss="alert"></button></div>';
            }
        });

        async function loadDocuments() {
            try {
                const response = await fetch(`/Client/Document/GetDocuments?loanApplicationId=${loanApplicationId}`);
                const data = await response.json();
                
                const tbody = document.querySelector('#documentsTable tbody');
                tbody.innerHTML = '';

                if (data.data && data.data.length > 0) {
                    data.data.forEach(doc => {
                        const uploadDate = new Date(doc.uploadedAt).toLocaleDateString('en-US', { 
                            year: 'numeric', 
                            month: 'short', 
                            day: 'numeric' 
                        });
                        
                        const statusClass = doc.status === 'Approved' ? 'bg-success' : 
                                          doc.status === 'Rejected' ? 'bg-danger' : 'bg-warning';
                        
                        const row = `
                            <tr>
                                <td><strong>${doc.documentType}</strong></td>
                                <td>${doc.fileName}</td>
                                <td>${uploadDate}</td>
                                <td><span class="badge ${statusClass}">${doc.status}</span></td>
                                <td>
                                    <button class="btn btn-sm btn-success" onclick="viewDocument(${doc.id}, '${doc.documentType}', '${doc.mimeType}')" title="View">
                                        <i class="bi bi-eye"></i> View
                                    </button>
                                    <button class="btn btn-sm btn-info" onclick="downloadDocument(${doc.id})" title="Download">
                                        <i class="bi bi-download"></i>
                                    </button>
                                    <button class="btn btn-sm btn-danger" onclick="deleteDocument(${doc.id})" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        `;
                        tbody.innerHTML += row;
                    });
                } else {
                    tbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted">No documents uploaded yet</td></tr>';
                }
            } catch (error) {
                console.error('Error loading documents:', error);
                tbody.innerHTML = '<tr><td colspan="5" class="text-center text-danger">Error loading documents</td></tr>';
            }
        }

        async function deleteDocument(documentId) {
            if (confirm('Are you sure you want to delete this document?')) {
                try {
                    const response = await fetch('/Client/Document/Delete', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({ documentId: documentId })
                    });

                    const data = await response.json();
                    if (data.success) {
                        loadDocuments();
                    } else {
                        alert(data.message || 'Error deleting document');
                    }
                } catch (error) {
                    console.error('Error deleting document:', error);
                    alert('Error deleting document');
                }
            }
        }

        function downloadDocument(documentId) {
            window.location.href = `/Client/Document/Download?documentId=${documentId}`;
        }

        function viewDocument(documentId, documentType, mimeType) {
            // Show modal with loading message
            const modalLabel = document.getElementById('viewerModalLabel');
            const viewerContent = document.getElementById('viewerContent');
            
            modalLabel.textContent = `View Document - ${documentType}`;
            viewerContent.innerHTML = '<div class="text-center"><p>Loading...</p></div>';

            // Determine viewer type based on MIME type
            if (mimeType && mimeType.includes('pdf')) {
                // Show PDF in iframe
                viewerContent.innerHTML = `
                    <iframe src="/Client/Document/ViewDocument?documentId=${documentId}" 
                        style="width: 100%; height: 600px; border: none;"></iframe>
                `;
            } else if (mimeType && (mimeType.includes('image') || mimeType.includes('jpeg') || mimeType.includes('png') || mimeType.includes('jpg'))) {
                // Show image
                viewerContent.innerHTML = `
                    <div class="text-center">
                        <img src="/Client/Document/ViewDocument?documentId=${documentId}" 
                            style="max-width: 100%; max-height: 600px;" alt="Document Preview">
                    </div>
                `;
            } else {
                // For other document types, show a message
                viewerContent.innerHTML = `
                    <div class="alert alert-info">
                        <p>This document type cannot be previewed in the browser.</p>
                        <p><strong>Document Type:</strong> ${documentType}</p>
                        <p><strong>MIME Type:</strong> ${mimeType || 'Unknown'}</p>
                        <p>Please download the document to view it.</p>
                    </div>
                `;
            }

            // Show the modal
            const modal = new bootstrap.Modal(document.getElementById('viewerModal'));
            modal.show();
        }
    </script>
}
