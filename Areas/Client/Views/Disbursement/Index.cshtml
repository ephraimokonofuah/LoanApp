@model List<LoanApp.Models.LoanDisbursement>

@{
    ViewData["Title"] = "My Disbursements";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1"><i class="bi bi-cash-stack text-primary me-2"></i>My Disbursements</h2>
            <p class="text-muted mb-0">Track the status of your loan disbursements.</p>
        </div>
    </div>

    @if (TempData["success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-1"></i> @TempData["success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">Application #</th>
                                <th>Approved Amount</th>
                                <th>Bank</th>
                                <th>Status</th>
                                <th>Created</th>
                                <th class="text-end pe-3">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var d in Model)
                            {
                                <tr>
                                    <td class="ps-3">#@d.LoanApplicationId</td>
                                    <td class="fw-semibold">@d.ApprovedAmount.ToString("C")</td>
                                    <td>@(d.Bank?.Name ?? "Not Selected")</td>
                                    <td>
                                        @switch (d.Status)
                                        {
                                            case LoanApp.Models.DisbursementStatus.PendingSetup:
                                                <span class="badge bg-secondary"><i class="bi bi-hourglass me-1"></i>Pending Setup</span>
                                                break;
                                            case LoanApp.Models.DisbursementStatus.BankSelected:
                                                <span class="badge bg-info"><i class="bi bi-bank me-1"></i>Bank Selected</span>
                                                break;
                                            case LoanApp.Models.DisbursementStatus.AccountDetailsSubmitted:
                                                <span class="badge bg-primary"><i class="bi bi-credit-card me-1"></i>Details Submitted</span>
                                                break;
                                            case LoanApp.Models.DisbursementStatus.ReadyForPayment:
                                                <span class="badge bg-warning text-dark"><i class="bi bi-cash me-1"></i>Ready for Payment</span>
                                                break;
                                            case LoanApp.Models.DisbursementStatus.Paid:
                                                <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Paid</span>
                                                break;
                                            case LoanApp.Models.DisbursementStatus.Failed:
                                                <span class="badge bg-danger"><i class="bi bi-x-circle me-1"></i>Failed</span>
                                                break;
                                        }
                                    </td>
                                    <td>@d.CreatedAt.ToString("dd MMM yyyy")</td>
                                    <td class="text-end pe-3">
                                        @if (d.Status == LoanApp.Models.DisbursementStatus.PendingSetup || d.Status == LoanApp.Models.DisbursementStatus.BankSelected)
                                        {
                                            <a asp-action="Setup" asp-route-loanApplicationId="@d.LoanApplicationId" class="btn btn-sm btn-primary me-1">
                                                <i class="bi bi-gear me-1"></i>Setup
                                            </a>
                                        }
                                        <a asp-action="Details" asp-route-id="@d.Id" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-eye me-1"></i>View
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-cash-stack text-muted" style="font-size:3rem;"></i>
            <p class="text-muted mt-2">No disbursements yet. Once your loan is approved, a disbursement will be created.</p>
        </div>
    }
</div>
