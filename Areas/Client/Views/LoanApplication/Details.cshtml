@model LoanApp.Models.LoanApplication

@{
    ViewData["Title"] = "Loan Application Details";
    var documents = ViewBag.Documents as List<LoanApp.Models.Document> ?? new List<LoanApp.Models.Document>();
}

<div class="container-fluid mt-4">
    <a asp-area="Client" asp-controller="LoanApplication" asp-action="Index" class="btn btn-outline-secondary mb-3">
        <i class="bi bi-arrow-left me-1"></i> Back to Dashboard
    </a>

    <!-- Application Status Timeline -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body py-4">
            <div class="d-flex position-relative">
                <div class="position-absolute" style="top:20px;left:12.5%;right:12.5%;height:3px;background:#e9ecef;z-index:0;"></div>
                @{
                    var steps = new[] { "Pending", "Documents Requested", "Under Review", "Approved" };
                    var currentIndex = Model.Status == "Rejected" ? -1
                        : Model.Status == "Approved" ? 3
                        : Model.Status == "Documents Requested" ? 1
                        : 0;
                }
                @for (int i = 0; i < steps.Length; i++)
                {
                    var isActive = i <= currentIndex && currentIndex >= 0;
                    var isCurrent = i == currentIndex;
                    <div class="text-center position-relative" style="z-index:1;flex:1;">
                        <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-2 @(isActive ? "bg-primary text-white" : "bg-light text-muted border")"
                             style="width:40px;height:40px;@(isCurrent ? "box-shadow:0 0 0 4px rgba(13,110,253,.25);" : "")">
                            @if (isActive)
                            {
                                <i class="bi bi-check"></i>
                            }
                            else
                            {
                                <span>@(i + 1)</span>
                            }
                        </div>
                        <div class="small @(isActive ? "fw-semibold" : "text-muted")">@steps[i]</div>
                    </div>
                }
            </div>
            @if (Model.Status == "Rejected")
            {
                <div class="text-center mt-3">
                    <span class="badge bg-danger fs-6"><i class="bi bi-x-circle me-1"></i>Application Rejected</span>
                </div>
            }
        </div>
    </div>

    <div class="row g-4">
        <!-- Left: Application Info -->
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="mb-0"><i class="bi bi-file-earmark-text me-2"></i>Application #@Model.Id</h5>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-5 text-muted">Loan Amount</dt>
                        <dd class="col-sm-7 fw-bold text-success fs-5">@Model.LoanAmount.ToString("C")</dd>

                        <dt class="col-sm-5 text-muted">Purpose</dt>
                        <dd class="col-sm-7">@Model.LoanPurpose</dd>

                        <dt class="col-sm-5 text-muted">Duration</dt>
                        <dd class="col-sm-7">@Model.DurationMonths months</dd>

                        <dt class="col-sm-5 text-muted">Interest Rate</dt>
                        <dd class="col-sm-7">@Model.InterestRate%</dd>

                        <dt class="col-sm-5 text-muted">Applied On</dt>
                        <dd class="col-sm-7">@Model.CreatedAt.ToString("dd MMM yyyy")</dd>

                        <dt class="col-sm-5 text-muted">Status</dt>
                        <dd class="col-sm-7">
                            @if (Model.Status == "Pending")
                            {
                                <span class="badge bg-warning text-dark"><i class="bi bi-hourglass-split me-1"></i>Pending</span>
                            }
                            else if (Model.Status == "Documents Requested")
                            {
                                <span class="badge bg-info"><i class="bi bi-file-earmark-arrow-up me-1"></i>Documents Requested</span>
                            }
                            else if (Model.Status == "Approved")
                            {
                                <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Approved</span>
                            }
                            else if (Model.Status == "Rejected")
                            {
                                <span class="badge bg-danger"><i class="bi bi-x-circle me-1"></i>Rejected</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@Model.Status</span>
                            }
                        </dd>
                    </dl>
                </div>
            </div>

            <!-- Admin Note (if documents requested) -->
            @if (Model.DocumentsRequested && !string.IsNullOrEmpty(Model.DocumentRequestNote))
            {
                <div class="card border-0 shadow-sm mt-3 border-start border-info border-4">
                    <div class="card-body">
                        <h6 class="fw-bold text-info"><i class="bi bi-chat-square-text me-1"></i> Message from Admin</h6>
                        <p class="mb-0 text-muted">@Model.DocumentRequestNote</p>
                    </div>
                </div>
            }

            <!-- Repayment Breakdown -->
            @{
                var repayment = LoanApp.Utility.LoanCalculator.Calculate(Model.LoanAmount, Model.InterestRate, Model.DurationMonths);
                var monthlyPayment = repayment.MonthlyPayment;
                var totalRepayment = repayment.TotalRepayment;
                var totalInterest = repayment.TotalInterest;
                var interestPercent = Model.LoanAmount > 0 ? (totalInterest / Model.LoanAmount * 100m) : 0m;
                var monthlyRatePercent = Model.InterestRate / 12m;
            }
            <div class="card border-0 shadow-sm mt-3">
                <div class="card-header bg-white py-3">
                    <h6 class="fw-bold mb-0"><i class="bi bi-calculator me-2 text-primary"></i>Repayment Breakdown</h6>
                </div>
                <div class="card-body">
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <div class="text-muted small">Loan Amount</div>
                            <div class="fw-bold">@Model.LoanAmount.ToString("C")</div>
                        </div>
                        <div class="col-6">
                            <div class="text-muted small">Annual Interest Rate</div>
                            <div class="fw-bold text-info">@Model.InterestRate% <span class="text-muted fw-normal small">per annum</span></div>
                        </div>
                        <div class="col-6">
                            <div class="text-muted small">Monthly Interest Rate</div>
                            <div class="fw-bold text-info">@monthlyRatePercent.ToString("F4")% <span class="text-muted fw-normal small">per month</span></div>
                        </div>
                        <div class="col-6">
                            <div class="text-muted small">Duration</div>
                            <div class="fw-bold">@Model.DurationMonths months</div>
                        </div>
                    </div>
                    <hr />
                    <div class="d-flex align-items-center mb-3">
                        <div class="rounded-circle bg-success bg-opacity-10 d-flex align-items-center justify-content-center me-3" style="width:50px;height:50px;">
                            <i class="bi bi-calendar-check text-success fs-5"></i>
                        </div>
                        <div>
                            <div class="text-muted small">Monthly Repayment</div>
                            <div class="fs-4 fw-bold text-success">@monthlyPayment.ToString("C")</div>
                        </div>
                    </div>
                    <div class="d-flex align-items-center mb-3">
                        <div class="rounded-circle bg-danger bg-opacity-10 d-flex align-items-center justify-content-center me-3" style="width:50px;height:50px;">
                            <i class="bi bi-cash-stack text-danger fs-5"></i>
                        </div>
                        <div>
                            <div class="text-muted small">Total Repayment</div>
                            <div class="fs-4 fw-bold text-danger">@totalRepayment.ToString("C")</div>
                            <div class="text-muted small">@Model.DurationMonths &times; @monthlyPayment.ToString("C")</div>
                        </div>
                    </div>
                    <div class="p-2 bg-light rounded small">
                        <i class="bi bi-info-circle text-info me-1"></i>
                        <span class="text-muted">Total interest cost: </span>
                        <strong class="text-danger">@totalInterest.ToString("C")</strong>
                        <span class="text-muted"> &mdash; that's @interestPercent.ToString("F1")% of your loan amount</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right: Documents -->
        <div class="col-lg-7">
            <!-- Upload Section (only visible when documents are requested) -->
            @if (Model.DocumentsRequested)
            {
                <div class="card border-0 shadow-sm mb-3 border-top border-info border-3">
                    <div class="card-header bg-white py-3">
                        <h5 class="fw-bold mb-0"><i class="bi bi-cloud-upload me-2 text-info"></i>Upload Documents</h5>
                    </div>
                    <div class="card-body">
                        <form id="uploadForm" enctype="multipart/form-data">
                            @Html.AntiForgeryToken()
                            <input type="hidden" id="loanApplicationId" value="@Model.Id" />
                            <div class="row g-3">
                                <div class="col-md-5">
                                    <label class="form-label small fw-semibold">Document Type</label>
                                    <select id="documentType" class="form-select form-select-sm" required>
                                        <option value="">Select type...</option>
                                        <option value="ProofOfIncome">Proof of Income</option>
                                        <option value="IdentityProof">Identity Proof</option>
                                        <option value="AddressProof">Address Proof</option>
                                        <option value="BankStatement">Bank Statement</option>
                                        <option value="CreditReport">Credit Report</option>
                                        <option value="EmploymentProof">Employment Proof</option>
                                        <option value="TaxReturn">Tax Return</option>
                                        <option value="Other">Other</option>
                                    </select>
                                </div>
                                <div class="col-md-5">
                                    <label class="form-label small fw-semibold">Choose File</label>
                                    <input type="file" id="file" class="form-control form-control-sm" accept=".pdf,.jpg,.jpeg,.png,.doc,.docx" required />
                                </div>
                                <div class="col-md-2 d-flex align-items-end">
                                    <button type="submit" class="btn btn-info text-white btn-sm w-100" id="uploadBtn">
                                        <i class="bi bi-upload me-1"></i>Upload
                                    </button>
                                </div>
                            </div>
                            <small class="text-muted mt-2 d-block">Allowed: PDF, JPG, PNG, DOC, DOCX (max 5MB)</small>
                        </form>
                        <div id="uploadMessage" class="mt-2"></div>
                    </div>
                </div>
            }

            <!-- Documents List -->
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0"><i class="bi bi-folder2-open me-2"></i>My Documents</h5>
                    <span class="badge bg-primary rounded-pill">@documents.Count</span>
                </div>
                <div class="card-body p-0" id="documentsList">
                    @if (documents.Any())
                    {
                        @foreach (var doc in documents)
                        {
                            <div class="border-bottom p-3 d-flex justify-content-between align-items-center">
                                <div class="d-flex align-items-center">
                                    <div class="rounded bg-light d-flex align-items-center justify-content-center me-3" style="width:44px;height:44px;">
                                        @if (doc.MimeType != null && doc.MimeType.Contains("pdf"))
                                        {
                                            <i class="bi bi-file-earmark-pdf text-danger fs-5"></i>
                                        }
                                        else if (doc.MimeType != null && doc.MimeType.Contains("image"))
                                        {
                                            <i class="bi bi-file-earmark-image text-success fs-5"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-file-earmark text-secondary fs-5"></i>
                                        }
                                    </div>
                                    <div>
                                        <h6 class="mb-0 fw-semibold small">@doc.DocumentType</h6>
                                        <small class="text-muted">@doc.FileName &middot; @((doc.FileSize / 1024.0).ToString("F1")) KB</small>
                                        @if (!string.IsNullOrEmpty(doc.ReviewNotes))
                                        {
                                            <br /><small class="text-muted fst-italic"><i class="bi bi-chat-text me-1"></i>@doc.ReviewNotes</small>
                                        }
                                    </div>
                                </div>
                                <div class="text-end">
                                    @if (doc.Status == "Pending")
                                    {
                                        <span class="badge bg-warning text-dark"><i class="bi bi-hourglass-split me-1"></i>Pending Review</span>
                                    }
                                    else if (doc.Status == "Approved")
                                    {
                                        <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Approved</span>
                                    }
                                    else if (doc.Status == "Rejected")
                                    {
                                        <span class="badge bg-danger"><i class="bi bi-x-circle me-1"></i>Rejected</span>
                                    }
                                    <br />
                                    <a href="/Client/Document/ViewDocument?documentId=@doc.Id" target="_blank" class="btn btn-sm btn-outline-primary mt-1">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a href="/Client/Document/Download?documentId=@doc.Id" class="btn btn-sm btn-outline-secondary mt-1">
                                        <i class="bi bi-download"></i>
                                    </a>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-folder text-muted" style="font-size:3rem;"></i>
                            @if (Model.DocumentsRequested)
                            {
                                <p class="text-muted mt-2 mb-0">No documents uploaded yet. Please use the form above to upload your documents.</p>
                            }
                            else
                            {
                                <p class="text-muted mt-2 mb-0">Documents have not been requested yet. The admin will notify you when documents are needed.</p>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@if (Model.DocumentsRequested)
{
    @section Scripts {
        <script>
            document.getElementById('uploadForm').addEventListener('submit', async function(e) {
                e.preventDefault();
                const btn = document.getElementById('uploadBtn');
                btn.disabled = true;
                btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Uploading...';

                const formData = new FormData();
                const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                formData.append('loanApplicationId', document.getElementById('loanApplicationId').value);
                formData.append('file', document.getElementById('file').files[0]);
                formData.append('documentType', document.getElementById('documentType').value);
                formData.append('__RequestVerificationToken', token);

                try {
                    const response = await fetch('/Client/Document/Upload', { method: 'POST', body: formData });
                    const data = await response.json();
                    if (data.success) {
                        document.getElementById('uploadMessage').innerHTML = '<div class="alert alert-success alert-dismissible fade show py-2 small"><i class="bi bi-check-circle me-1"></i>Document uploaded successfully!<button class="btn-close btn-close-sm" data-bs-dismiss="alert"></button></div>';
                        document.getElementById('uploadForm').reset();
                        setTimeout(() => location.reload(), 1000);
                    } else {
                        document.getElementById('uploadMessage').innerHTML = `<div class="alert alert-danger alert-dismissible fade show py-2 small">${data.message}<button class="btn-close" data-bs-dismiss="alert"></button></div>`;
                    }
                } catch (error) {
                    document.getElementById('uploadMessage').innerHTML = '<div class="alert alert-danger py-2 small">Upload failed. Please try again.</div>';
                }
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-upload me-1"></i>Upload';
            });
        </script>
    }
}
