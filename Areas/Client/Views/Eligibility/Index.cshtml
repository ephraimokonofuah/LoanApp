@model List<LoanApp.Models.EligibilityCheck>

@{
    ViewData["Title"] = "My Eligibility Checks";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3><i class="bi bi-clipboard-check me-2"></i>My Eligibility Checks</h3>
        <a asp-action="Check" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>New Check
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>You haven't performed any eligibility checks yet.
            <a asp-action="Check" class="alert-link">Check your eligibility now</a>.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table id="eligibilityTable" class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Loan Type</th>
                        <th>Amount</th>
                        <th>Duration</th>
                        <th>Eligible</th>
                        <th>Admin Status</th>
                        <th>Date</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.LoanType?.Name</td>
                            <td>@item.DesiredLoanAmount.ToString("C")</td>
                            <td>@item.DurationMonths months</td>
                            <td>
                                @if (item.IsEligible)
                                {
                                    <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Eligible</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger"><i class="bi bi-x-circle me-1"></i>Not Eligible</span>
                                }
                            </td>
                            <td>
                                @switch (item.Status)
                                {
                                    case "Approved":
                                        <span class="badge bg-success">Approved</span>
                                        break;
                                    case "Rejected":
                                        <span class="badge bg-danger">Rejected</span>
                                        break;
                                    default:
                                        <span class="badge bg-warning text-dark">Pending Review</span>
                                        break;
                                }
                            </td>
                            <td>@item.CreatedAt.ToString("dd MMM yyyy")</td>
                            <td>
                                <a asp-action="Result" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-eye"></i> View
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#eligibilityTable').DataTable();
        });
    </script>
}
