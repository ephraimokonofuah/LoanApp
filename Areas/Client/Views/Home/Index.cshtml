<!-- ========== FAQ SECTION ========== -->
<section class="mb-5">
    <div class="container">
        <div class="text-center mb-5">
            <span class="badge bg-info bg-opacity-10 text-info px-3 py-2 rounded-pill mb-2">FAQ</span>
            <h2 class="display-6 fw-bold">Frequently Asked Questions</h2>
        </div>
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="accordion" id="faqAccordion">
                    <div class="accordion-item border-0 mb-2 rounded-3 shadow-sm">
                        <h2 class="accordion-header">
                            <button class="accordion-button fw-semibold" type="button" data-bs-toggle="collapse" data-bs-target="#faq1">
                                How quickly can I get approved?
                            </button>
                        </h2>
                        <div id="faq1" class="accordion-collapse collapse show" data-bs-parent="#faqAccordion">
                            <div class="accordion-body text-muted small">
                                Most applications are reviewed and approved within 24 hours. Once approved, funds are typically disbursed within 1-2 business days depending on your bank.
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item border-0 mb-2 rounded-3 shadow-sm">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed fw-semibold" type="button" data-bs-toggle="collapse" data-bs-target="#faq2">
                                Does the eligibility check affect my credit score?
                            </button>
                        </h2>
                        <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body text-muted small">
                                No. Our eligibility check is a soft inquiry that does not impact your credit score. You can check your eligibility with confidence.
                            </div>
                        </div>
                    </div>
