@{
    ViewData["Title"] = "Home";
    var loanTypes = ViewBag.LoanTypes as List<LoanApp.Models.LoanType> ?? new List<LoanApp.Models.LoanType>();
    var siteSettings = ViewBag.SiteSettings as LoanApp.Models.SiteSettings;
    var siteName = siteSettings?.SiteName ?? "LoanApp";
}

<!-- ========== HERO SECTION ========== -->
<section class="hero-section position-relative overflow-hidden rounded-4 mb-5">
    <div class="hero-gradient"></div>
    <div class="container position-relative" style="z-index: 2;">
        <div class="row align-items-center min-vh-75 py-5">
            <div class="col-lg-6 text-white">
                <span class="badge bg-warning text-dark px-3 py-2 mb-3 rounded-pill fw-semibold">
                    <i class="bi bi-lightning-charge-fill me-1"></i>Loans Approved in 24 Hours
                </span>
                <h1 class="display-3 fw-bold lh-sm mb-3">
                    Your Financial Goals,<br>
                    <span class="text-warning">Made Possible.</span>
                </h1>
                <p class="lead opacity-75 mb-4" style="max-width: 500px;">
                    Whether it's a new home, education, business, or personal needs — 
                    we offer competitive rates, transparent terms, and a seamless digital experience.
                </p>
                <div class="d-flex flex-wrap gap-3 mb-4">
                    <a asp-area="Client" asp-controller="Eligibility" asp-action="Check" class="btn btn-warning btn-lg px-4 fw-semibold shadow">
                        <i class="bi bi-check-circle me-2"></i>Check Eligibility
                    </a>
                    <a href="#loan-products" class="btn btn-outline-light btn-lg px-4">
                        <i class="bi bi-arrow-down-circle me-2"></i>Explore Products
                    </a>
                </div>
                <div class="d-flex gap-4 mt-4">
                    <div class="text-center">
                        <h3 class="fw-bold text-warning mb-0">$50M+</h3>
                        <small class="opacity-75">Loans Disbursed</small>
                    </div>
                    <div class="vr bg-white opacity-25"></div>
                    <div class="text-center">
                        <h3 class="fw-bold text-warning mb-0">15K+</h3>
                        <small class="opacity-75">Happy Clients</small>
                    </div>
                    <div class="vr bg-white opacity-25"></div>
                    <div class="text-center">
                        <h3 class="fw-bold text-warning mb-0">@(loanTypes.Any() ? loanTypes.Min(lt => lt.InterestRate).ToString("0.#") : "3.5")%</h3>
                        <small class="opacity-75">Rates From</small>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 d-none d-lg-block text-center">
                <div class="hero-image-wrapper">
                    <div class="hero-card card border-0 shadow-lg p-4" style="max-width: 400px; margin: 0 auto;">
                        <div class="text-center mb-3">
                            <div class="bg-primary bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 64px; height: 64px;">
                                <i class="bi bi-calculator fs-2 text-primary"></i>
                            </div>
                        </div>
                        <h5 class="fw-bold text-center mb-3">Quick Estimate</h5>
                        <div class="bg-light rounded-3 p-3 mb-2">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="text-muted small">Loan Amount</span>
                                <span class="fw-semibold">$25,000</span>
                            </div>
                            <div class="d-flex justify-content-between mb-1">
                                <span class="text-muted small">Interest Rate</span>
                                <span class="fw-semibold">5.5%</span>
                            </div>
                            <div class="d-flex justify-content-between mb-1">
                                <span class="text-muted small">Duration</span>
                                <span class="fw-semibold">36 months</span>
                            </div>
                            <hr class="my-2">
                            <div class="d-flex justify-content-between">
                                <span class="fw-bold">Monthly Payment</span>
                                <span class="fw-bold text-success fs-5">$753.97</span>
                            </div>
                        </div>
                        <a asp-area="Client" asp-controller="Eligibility" asp-action="Check" class="btn btn-primary w-100 mt-2">
                            Calculate Yours <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ========== TRUST BAR ========== -->
<section class="py-4 mb-5">
    <div class="container">
        <div class="row g-3 text-center">
            <div class="col-6 col-md-3">
                <div class="d-flex align-items-center justify-content-center gap-2">
                    <i class="bi bi-shield-lock-fill fs-4 text-success"></i>
                    <span class="fw-semibold small">256-bit SSL Encrypted</span>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="d-flex align-items-center justify-content-center gap-2">
                    <i class="bi bi-bank fs-4 text-primary"></i>
                    <span class="fw-semibold small">FDIC Insured</span>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="d-flex align-items-center justify-content-center gap-2">
                    <i class="bi bi-clock-history fs-4 text-warning"></i>
                    <span class="fw-semibold small">24hr Approval</span>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="d-flex align-items-center justify-content-center gap-2">
                    <i class="bi bi-headset fs-4 text-info"></i>
                    <span class="fw-semibold small">Dedicated Support</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ========== HOW IT WORKS ========== -->
<section class="mb-5">
    <div class="container">
        <div class="text-center mb-5">
            <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 rounded-pill mb-2">Simple Process</span>
            <h2 class="display-6 fw-bold">How It Works</h2>
            <p class="text-muted mx-auto" style="max-width: 550px;">Get funded in four easy steps — no paperwork headaches, no hidden fees.</p>
        </div>
        <div class="row g-4">
            <div class="col-md-6 col-lg-3">
                <div class="text-center position-relative">
                    <div class="step-number bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 56px; height: 56px; font-size: 1.25rem; font-weight: 700;">1</div>
                    <h5 class="fw-bold">Check Eligibility</h5>
                    <p class="text-muted small">Answer a few questions and instantly see if you qualify and your estimated rate.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="text-center position-relative">
                    <div class="step-number bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 56px; height: 56px; font-size: 1.25rem; font-weight: 700;">2</div>
                    <h5 class="fw-bold">Apply Online</h5>
                    <p class="text-muted small">Complete your application in minutes with our secure digital form.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="text-center position-relative">
                    <div class="step-number bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 56px; height: 56px; font-size: 1.25rem; font-weight: 700;">3</div>
                    <h5 class="fw-bold">Get Approved</h5>
                    <p class="text-muted small">Our team reviews your application and you get a decision within 24 hours.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="text-center position-relative">
                    <div class="step-number bg-success text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 56px; height: 56px; font-size: 1.25rem; font-weight: 700;">4</div>
                    <h5 class="fw-bold">Receive Funds</h5>
                    <p class="text-muted small">Funds are disbursed directly to your account with a clear repayment schedule.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ========== LOAN PRODUCTS ========== -->
<section id="loan-products" class="bg-light py-5 rounded-4 mb-5">
    <div class="container">
        <div class="text-center mb-5">
            <span class="badge bg-success bg-opacity-10 text-success px-3 py-2 rounded-pill mb-2">Our Products</span>
            <h2 class="display-6 fw-bold">Loan Products Tailored for You</h2>
            <p class="text-muted mx-auto" style="max-width: 550px;">From personal goals to major investments, we have the right loan for every need.</p>
        </div>
        <div class="row g-4">
            <!-- Personal Loan -->
            <div class="col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm h-100 loan-product-card">
                    <div class="card-body p-4">
                        <div class="bg-primary bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 52px; height: 52px;">
                            <i class="bi bi-person-fill fs-4 text-primary"></i>
                        </div>
                        <h5 class="fw-bold">Personal Loan</h5>
                        <p class="text-muted small mb-3">For medical bills, vacations, weddings, or unexpected expenses. Fast and flexible.</p>
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="text-muted small">Interest Rate</span>
                            <span class="badge bg-primary bg-opacity-10 text-primary">From @(loanTypes.FirstOrDefault(l => l.Name.Contains("Personal"))?.InterestRate.ToString("0.#") ?? "12.0")%</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-muted small">Max Amount</span>
                            <span class="fw-semibold">$50,000</span>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Business Loan -->
            <div class="col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm h-100 loan-product-card">
                    <div class="card-body p-4">
                        <div class="bg-warning bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 52px; height: 52px;">
                            <i class="bi bi-briefcase-fill fs-4 text-warning"></i>
                        </div>
                        <h5 class="fw-bold">Business Loan</h5>
                        <p class="text-muted small mb-3">Start, expand, or manage your business with funding designed for entrepreneurs.</p>
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="text-muted small">Interest Rate</span>
                            <span class="badge bg-warning bg-opacity-10 text-warning">From @(loanTypes.FirstOrDefault(l => l.Name.Contains("Business"))?.InterestRate.ToString("0.#") ?? "8.0")%</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-muted small">Max Amount</span>
                            <span class="fw-semibold">$200,000</span>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Education Loan -->
            <div class="col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm h-100 loan-product-card">
                    <div class="card-body p-4">
                        <div class="bg-info bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 52px; height: 52px;">
                            <i class="bi bi-mortarboard-fill fs-4 text-info"></i>
                        </div>
                        <h5 class="fw-bold">Education Loan</h5>
                        <p class="text-muted small mb-3">Invest in your future. Cover tuition, books, accommodation and more.</p>
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="text-muted small">Interest Rate</span>
                            <span class="badge bg-info bg-opacity-10 text-info">From @(loanTypes.FirstOrDefault(l => l.Name.Contains("Education"))?.InterestRate.ToString("0.#") ?? "5.5")%</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-muted small">Max Amount</span>
                            <span class="fw-semibold">$100,000</span>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Mortgage Loan -->
            <div class="col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm h-100 loan-product-card">
                    <div class="card-body p-4">
                        <div class="bg-success bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 52px; height: 52px;">
                            <i class="bi bi-house-door-fill fs-4 text-success"></i>
                        </div>
                        <h5 class="fw-bold">Mortgage Loan</h5>
                        <p class="text-muted small mb-3">Buy your dream home or refinance with our lowest available rates.</p>
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="text-muted small">Interest Rate</span>
                            <span class="badge bg-success bg-opacity-10 text-success">From @(loanTypes.FirstOrDefault(l => l.Name.Contains("Mortgage"))?.InterestRate.ToString("0.#") ?? "3.5")%</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-muted small">Max Amount</span>
                            <span class="fw-semibold">$500,000</span>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Auto Loan -->
            <div class="col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm h-100 loan-product-card">
                    <div class="card-body p-4">
                        <div class="bg-danger bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 52px; height: 52px;">
                            <i class="bi bi-car-front-fill fs-4 text-danger"></i>
                        </div>
                        <h5 class="fw-bold">Auto Loan</h5>
                        <p class="text-muted small mb-3">New or used, get behind the wheel with affordable financing options.</p>
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="text-muted small">Interest Rate</span>
                            <span class="badge bg-danger bg-opacity-10 text-danger">From @(loanTypes.FirstOrDefault(l => l.Name.Contains("Auto"))?.InterestRate.ToString("0.#") ?? "6.5")%</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-muted small">Max Amount</span>
                            <span class="fw-semibold">$75,000</span>
                        </div>
                    </div>
                </div>
            </div>
            <!-- CTA Card -->
            <div class="col-md-6 col-lg-4">
                <div class="card border-0 bg-primary text-white h-100 shadow">
                    <div class="card-body p-4 d-flex flex-column justify-content-center text-center">
                        <i class="bi bi-patch-check-fill fs-1 mb-3"></i>
                        <h5 class="fw-bold">Not Sure Which Loan?</h5>
                        <p class="opacity-75 small mb-3">Take our free eligibility check to discover which products you qualify for.</p>
                        <a asp-area="Client" asp-controller="Eligibility" asp-action="Check" class="btn btn-warning fw-semibold">
                            Check Now <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

