@{
    ViewData["Title"] = "Home Page";
}

<!-- Hero Section -->

    <div class="row align-items-center">

        <!-- Text Content -->
        <div class="col-lg-6">
            <h1 class="display-4 fw-bold">Fast & Reliable Loans</h1>
            <p class="lead text-muted">
                Apply for personal or business loans in minutes. Our simple process 
                helps you get the funds you need without unnecessary delays.
            </p>

            <div class="mt-4">
                <a asp-area="Client" asp-controller="LoanApplication" asp-action="Create" class="btn btn-primary btn-lg me-3">
                    Apply for a Loan
                </a>

                <a asp-area="Client" asp-controller="LoanApplication" asp-action="Index" class="btn btn-outline-secondary btn-lg">
                    Check Applications
                </a>
            </div>

            <div class="mt-4 text-muted">
                <small>✔ Quick Approval</small><br>
                <small>✔ Transparent Interest Rates</small><br>
                <small>✔ Flexible Repayment Plans</small>
            </div>
        </div>

        <!-- Image Section -->
        <div class="col-lg-6 text-center">
            <img src="https://images.unsplash.com/photo-1554224155-6726b3ff858f"
                 class="img-fluid rounded shadow"
                 alt="Loan service">
        </div>

    </div>


<!-- Features Section -->
<div class="bg-light py-5 my-5 rounded">
    <div class="container">
        <div class="text-center mb-5">
            <h2>Why Choose Our Loan Platform?</h2>
            <p class="text-muted">Simple, transparent and secure loan management</p>
        </div>

        <div class="row g-4">

            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100 text-center p-3">
                    <div class="card-body">
                        <h4>Easy Application</h4>
                        <p class="text-muted">
                            Complete your loan application in just a few minutes
                            using our simple online form.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100 text-center p-3">
                    <div class="card-body">
                        <h4>Quick Approval</h4>
                        <p class="text-muted">
                            Our system processes loan requests quickly so you
                            can get the funds you need.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100 text-center p-3">
                    <div class="card-body">
                        <h4>Flexible Repayment</h4>
                        <p class="text-muted">
                            Choose repayment plans that fit your financial
                            situation comfortably.
                        </p>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- Call To Action -->
<div class="container py-5 text-center">
    <h2>Need a Loan Today?</h2>
    <p class="text-muted">
        Start your loan application now and receive a decision quickly.
    </p>

    <a href="/LoanApplications/Create" class="btn btn-success btn-lg">
        Start Loan Application
    </a>
</div>