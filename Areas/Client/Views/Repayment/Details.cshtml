@model LoanApp.Models.Repayment

@{
    ViewData["Title"] = $"Installment #{Model.InstallmentNumber}";

    var statusBadge = Model.Status switch
    {
        RepaymentStatus.Paid => ("bg-success", "bi-check-circle", "Paid"),
        RepaymentStatus.Due => ("bg-warning text-dark", "bi-clock", "Due"),
        RepaymentStatus.Missed => ("bg-danger", "bi-exclamation-triangle", "Missed Payment"),
        RepaymentStatus.PaymentRequested => ("bg-info", "bi-send", "Payment Requested"),
        RepaymentStatus.DetailsSent => ("bg-primary", "bi-envelope-check", "Payment Details Sent"),
        _ => ("bg-secondary", "bi-hourglass", "Upcoming")
    };

    var methodLabel = Model.PaymentMethodRequested switch
    {
        PaymentMethodType.USDT => ("bi-currency-exchange", "USDT (Tether)", "bg-success"),
        PaymentMethodType.Bitcoin => ("bi-currency-bitcoin", "Bitcoin", "bg-warning text-dark"),
        PaymentMethodType.BankTransfer => ("bi-bank", "Bank Transfer", "bg-primary"),
        _ => ("bi-dash", "Not Selected", "bg-secondary")
    };
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-1">
                <i class="bi bi-receipt text-primary me-2"></i>Installment #@Model.InstallmentNumber
            </h3>
            <p class="text-muted mb-0">
                Due: @Model.DueDate.ToString("dd MMMM yyyy") &bull;
                <span class="badge @statusBadge.Item1"><i class="bi @statusBadge.Item2 me-1"></i>@statusBadge.Item3</span>
            </p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back to Schedule
        </a>
    </div>

    @if (TempData["success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-1"></i> @TempData["success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle me-1"></i> @TempData["error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">
        <!-- Payment Details Card -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-info-circle me-2"></i>Payment Information</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-6">
                            <div class="text-muted small">Installment</div>
                            <div class="fw-bold">#@Model.InstallmentNumber of @Model.Loan?.DurationMonths</div>
                        </div>
                        <div class="col-6">
                            <div class="text-muted small">Due Date</div>
                            <div class="fw-bold">@Model.DueDate.ToString("dd MMM yyyy")</div>
                        </div>
                        <div class="col-6">
                            <div class="text-muted small">Principal</div>
                            <div class="fw-bold">$@Model.PrincipalPortion.ToString("N2")</div>
                        </div>
                        <div class="col-6">
                            <div class="text-muted small">Interest</div>
                            <div class="fw-bold">$@Model.InterestPortion.ToString("N2")</div>
                        </div>
                        <div class="col-12">
                            <hr class="my-1" />
                        </div>
                        <div class="col-12">
                            <div class="text-muted small">Total Amount Due</div>
                            <div class="fw-bold text-primary fs-4">$@Model.Amount.ToString("N2")</div>
                        </div>
                        @if (Model.PaidAt.HasValue)
                        {
                            <div class="col-6">
                                <div class="text-muted small">Paid On</div>
                                <div class="fw-bold text-success">@Model.PaidAt.Value.ToString("dd MMM yyyy HH:mm")</div>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.TransactionReference))
                        {
                            <div class="col-6">
                                <div class="text-muted small">Transaction Reference</div>
                                <div class="fw-bold"><code>@Model.TransactionReference</code></div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Status / Action Card -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-lightning me-2"></i>Payment Action</h5>
                </div>
                <div class="card-body">
                    @if (Model.Status == RepaymentStatus.Paid)
                    {
                        <div class="text-center py-4">
                            <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
                            <h5 class="mt-3 text-success fw-bold">Payment Complete</h5>
                            <p class="text-muted">This installment has been successfully paid.</p>
                        </div>
                    }
                    else if (Model.Status == RepaymentStatus.Upcoming || Model.Status == RepaymentStatus.Due || Model.Status == RepaymentStatus.Missed)
                    {
                        @if (Model.Status == RepaymentStatus.Upcoming)
                        {
                            <div class="alert alert-info d-flex align-items-center mb-3">
                                <i class="bi bi-lightning-fill me-2 fs-5"></i>
                                <div>
                                    <strong>Early Payment</strong> — This installment is not yet due until <strong>@Model.DueDate.ToString("dd MMMM yyyy")</strong>, but you can pay ahead of time.
                                </div>
                            </div>
                        }
                        @if (Model.Status == RepaymentStatus.Missed)
                        {
                            <div class="alert alert-danger d-flex align-items-center mb-3">
                                <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
                                <div>
                                    <strong>Missed Payment</strong> — This payment is overdue. Please make the payment as soon as possible to avoid penalties.
                                </div>
                            </div>
                        }
                        <h6 class="fw-bold mb-3">
                            <i class="bi bi-wallet2 me-2"></i>Request Payment Details
                        </h6>
                        <p class="text-muted small mb-3">Select your preferred payment method. The admin will send you the payment details.</p>

                        <form asp-action="RequestPayment" method="post">
                            <input type="hidden" name="id" value="@Model.Id" />

                            <div class="d-grid gap-2">
                                <button type="submit" name="paymentMethod" value="@PaymentMethodType.USDT"
                                        class="btn btn-outline-success btn-lg d-flex align-items-center justify-content-between">
                                    <span><i class="bi bi-currency-exchange me-2"></i>USDT (Tether)</span>
                                    <i class="bi bi-chevron-right"></i>
                                </button>
                                <button type="submit" name="paymentMethod" value="@PaymentMethodType.Bitcoin"
                                        class="btn btn-outline-warning btn-lg d-flex align-items-center justify-content-between">
                                    <span><i class="bi bi-currency-bitcoin me-2"></i>Bitcoin</span>
                                    <i class="bi bi-chevron-right"></i>
                                </button>
                                <button type="submit" name="paymentMethod" value="@PaymentMethodType.BankTransfer"
                                        class="btn btn-outline-primary btn-lg d-flex align-items-center justify-content-between">
                                    <span><i class="bi bi-bank me-2"></i>Bank Transfer</span>
                                    <i class="bi bi-chevron-right"></i>
                                </button>
                            </div>
                        </form>
                    }
                    else if (Model.Status == RepaymentStatus.PaymentRequested)
                    {
                        <div class="text-center py-4">
                            <i class="bi bi-hourglass-split text-info" style="font-size: 4rem;"></i>
                            <h5 class="mt-3 text-info fw-bold">Payment Requested</h5>
                            <p class="text-muted">
                                You requested <span class="badge @methodLabel.Item3"><i class="bi @methodLabel.Item1 me-1"></i>@methodLabel.Item2</span> payment details.
                            </p>
                            <p class="text-muted small">Please wait while the admin prepares and sends you the payment details.</p>
                            @if (Model.PaymentRequestedAt.HasValue)
                            {
                                <small class="text-muted">Requested on @Model.PaymentRequestedAt.Value.ToString("dd MMM yyyy HH:mm")</small>
                            }
                        </div>
                    }
                    else if (Model.Status == RepaymentStatus.DetailsSent)
                    {
                        <div class="mb-3">
                            <div class="alert alert-primary d-flex align-items-start">
                                <i class="bi bi-envelope-check-fill me-2 fs-4"></i>
                                <div>
                                    <strong>Payment Details Received!</strong>
                                    <p class="mb-0 small">The admin has sent you the payment details for
                                        <span class="badge @methodLabel.Item3"><i class="bi @methodLabel.Item1 me-1"></i>@methodLabel.Item2</span>
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="card bg-light border-0 mb-3">
                            <div class="card-body">
                                <h6 class="fw-bold mb-2"><i class="bi bi-key me-2"></i>Payment Details</h6>
                                <div class="bg-white rounded p-3 border" style="white-space: pre-wrap; word-break: break-all;">@Model.PaymentDetails</div>
                            </div>
                        </div>

                        @if (Model.PaymentDetailsSentAt.HasValue)
                        {
                            <small class="text-muted d-block mb-3">Details sent on @Model.PaymentDetailsSentAt.Value.ToString("dd MMM yyyy HH:mm")</small>
                        }

                        <form asp-action="ConfirmPayment" method="post">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <div class="mb-3">
                                <label class="form-label fw-bold">Transaction Reference / Proof</label>
                                <input type="text" name="transactionReference" class="form-control"
                                       placeholder="Enter your transaction ID or reference number"
                                       value="@Model.TransactionReference" />
                                <div class="form-text">Provide your transaction reference after making the payment.</div>
                            </div>
                            <button type="submit" class="btn btn-success w-100">
                                <i class="bi bi-check2-circle me-1"></i>Submit Transaction Reference
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Timeline -->
    <div class="card border-0 shadow-sm mt-4">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0 fw-bold"><i class="bi bi-clock-history me-2"></i>Activity Timeline</h5>
        </div>
        <div class="card-body">
            <div class="timeline">
                <div class="timeline-item">
                    <div class="d-flex align-items-start">
                        <div class="timeline-icon bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width:36px; height:36px; min-width:36px;">
                            <i class="bi bi-calendar-plus"></i>
                        </div>
                        <div>
                            <div class="fw-bold">Installment Created</div>
                            <small class="text-muted">Due on @Model.DueDate.ToString("dd MMM yyyy")</small>
                        </div>
                    </div>
                </div>

                @if (Model.PaymentRequestedAt.HasValue)
                {
                    <div class="timeline-item mt-3">
                        <div class="d-flex align-items-start">
                            <div class="timeline-icon bg-info text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width:36px; height:36px; min-width:36px;">
                                <i class="bi bi-send"></i>
                            </div>
                            <div>
                                <div class="fw-bold">Payment Requested — @methodLabel.Item2</div>
                                <small class="text-muted">@Model.PaymentRequestedAt.Value.ToString("dd MMM yyyy HH:mm")</small>
                            </div>
                        </div>
                    </div>
                }

                @if (Model.PaymentDetailsSentAt.HasValue)
                {
                    <div class="timeline-item mt-3">
                        <div class="d-flex align-items-start">
                            <div class="timeline-icon bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width:36px; height:36px; min-width:36px;">
                                <i class="bi bi-envelope-check"></i>
                            </div>
                            <div>
                                <div class="fw-bold">Payment Details Sent by Admin</div>
                                <small class="text-muted">@Model.PaymentDetailsSentAt.Value.ToString("dd MMM yyyy HH:mm")</small>
                            </div>
                        </div>
                    </div>
                }

                @if (Model.PaidAt.HasValue)
                {
                    <div class="timeline-item mt-3">
                        <div class="d-flex align-items-start">
                            <div class="timeline-icon bg-success text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width:36px; height:36px; min-width:36px;">
                                <i class="bi bi-check-circle"></i>
                            </div>
                            <div>
                                <div class="fw-bold">Payment Confirmed</div>
                                <small class="text-muted">@Model.PaidAt.Value.ToString("dd MMM yyyy HH:mm")</small>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
