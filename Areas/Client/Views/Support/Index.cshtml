@model List<LoanApp.Models.SupportTicket>

@{
    ViewData["Title"] = "My Support Tickets";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-1"><i class="bi bi-headset text-primary me-2"></i>My Support Tickets</h3>
            <p class="text-muted mb-0">Track your support requests and communicate with our team.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>New Ticket
        </a>
    </div>

    @if (TempData["success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-1"></i> @TempData["success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle me-1"></i> @TempData["error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Summary Cards -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center py-3">
                    <div class="mb-1"><i class="bi bi-ticket-detailed text-primary" style="font-size: 1.5rem;"></i></div>
                    <h4 class="fw-bold mb-0">@Model.Count</h4>
                    <small class="text-muted">Total Tickets</small>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center py-3">
                    <div class="mb-1"><i class="bi bi-envelope-open text-warning" style="font-size: 1.5rem;"></i></div>
                    <h4 class="fw-bold mb-0">@Model.Count(t => t.Status == LoanApp.Models.TicketStatus.Open || t.Status == LoanApp.Models.TicketStatus.InProgress)</h4>
                    <small class="text-muted">Active</small>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center py-3">
                    <div class="mb-1"><i class="bi bi-clock-history text-info" style="font-size: 1.5rem;"></i></div>
                    <h4 class="fw-bold mb-0">@Model.Count(t => t.Status == LoanApp.Models.TicketStatus.AwaitingResponse)</h4>
                    <small class="text-muted">Awaiting Reply</small>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center py-3">
                    <div class="mb-1"><i class="bi bi-check-circle text-success" style="font-size: 1.5rem;"></i></div>
                    <h4 class="fw-bold mb-0">@Model.Count(t => t.Status == LoanApp.Models.TicketStatus.Resolved || t.Status == LoanApp.Models.TicketStatus.Closed)</h4>
                    <small class="text-muted">Resolved</small>
                </div>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <i class="bi bi-chat-dots text-muted" style="font-size: 4rem;"></i>
                <h5 class="mt-3 text-muted">No Support Tickets Yet</h5>
                <p class="text-muted">Need help? Create a support ticket and our team will get back to you.</p>
                <a asp-action="Create" class="btn btn-primary mt-2">
                    <i class="bi bi-plus-circle me-1"></i>Create Your First Ticket
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table id="ticketTable" class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Ticket #</th>
                                <th>Subject</th>
                                <th>Category</th>
                                <th>Priority</th>
                                <th>Status</th>
                                <th>Messages</th>
                                <th>Last Updated</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ticket in Model)
                            {
                                <tr class="@(!ticket.IsReadByUser ? "table-active fw-semibold" : "")">
                                    <td>
                                        <span class="text-primary fw-semibold">@ticket.TicketNumber</span>
                                        @if (!ticket.IsReadByUser)
                                        {
                                            <span class="badge bg-danger ms-1" style="font-size: 0.6rem;">NEW</span>
                                        }
                                    </td>
                                    <td>@ticket.Subject</td>
                                    <td>
                                        <span class="badge bg-light text-dark border">
                                            @switch (ticket.Category)
                                            {
                                                case LoanApp.Models.TicketCategory.LoanApplication:
                                                    <i class="bi bi-file-earmark-text me-1"></i>
                                                    break;
                                                case LoanApp.Models.TicketCategory.Disbursement:
                                                    <i class="bi bi-cash-coin me-1"></i>
                                                    break;
                                                case LoanApp.Models.TicketCategory.AccountIssue:
                                                    <i class="bi bi-person-exclamation me-1"></i>
                                                    break;
                                                case LoanApp.Models.TicketCategory.DocumentUpload:
                                                    <i class="bi bi-cloud-upload me-1"></i>
                                                    break;
                                                case LoanApp.Models.TicketCategory.PaymentIssue:
                                                    <i class="bi bi-credit-card me-1"></i>
                                                    break;
                                                case LoanApp.Models.TicketCategory.TechnicalSupport:
                                                    <i class="bi bi-gear me-1"></i>
                                                    break;
                                                default:
                                                    <i class="bi bi-chat-dots me-1"></i>
                                                    break;
                                            }
                                            @ticket.Category
                                        </span>
                                    </td>
                                    <td>
                                        @switch (ticket.Priority)
                                        {
                                            case LoanApp.Models.TicketPriority.Low:
                                                <span class="badge bg-secondary">Low</span>
                                                break;
                                            case LoanApp.Models.TicketPriority.Medium:
                                                <span class="badge bg-info">Medium</span>
                                                break;
                                            case LoanApp.Models.TicketPriority.High:
                                                <span class="badge bg-warning text-dark">High</span>
                                                break;
                                            case LoanApp.Models.TicketPriority.Urgent:
                                                <span class="badge bg-danger">Urgent</span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        @switch (ticket.Status)
                                        {
                                            case LoanApp.Models.TicketStatus.Open:
                                                <span class="badge bg-primary">Open</span>
                                                break;
                                            case LoanApp.Models.TicketStatus.InProgress:
                                                <span class="badge bg-info">In Progress</span>
                                                break;
                                            case LoanApp.Models.TicketStatus.AwaitingResponse:
                                                <span class="badge bg-warning text-dark">Awaiting Response</span>
                                                break;
                                            case LoanApp.Models.TicketStatus.Resolved:
                                                <span class="badge bg-success">Resolved</span>
                                                break;
                                            case LoanApp.Models.TicketStatus.Closed:
                                                <span class="badge bg-secondary">Closed</span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        <span class="badge bg-light text-dark border">
                                            <i class="bi bi-chat-left-text me-1"></i>@ticket.Messages.Count
                                        </span>
                                    </td>
                                    <td>@ticket.UpdatedAt.ToString("dd MMM yyyy HH:mm")</td>
                                    <td>
                                        <a asp-action="Details" asp-route-id="@ticket.Id" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-eye me-1"></i>View
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#ticketTable').DataTable({
                order: [[6, 'desc']],
                language: {
                    emptyTable: "No tickets found"
                }
            });
        });
    </script>
}
