@model LoanApp.Models.ViewModels.DisbursementUpdateViewModel

@{
    ViewData["Title"] = "Disbursement Details";
}

<div class="container mt-4" style="max-width: 800px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0"><i class="bi bi-cash-stack text-primary me-2"></i>Disbursement #@Model.DisbursementId</h2>
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back to List</a>
    </div>

    @if (TempData["success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-1"></i> @TempData["success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle me-1"></i> @TempData["error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Disbursement Info Card -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-white">
            <h5 class="fw-bold mb-0"><i class="bi bi-info-circle me-2"></i>Disbursement Information</h5>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label text-muted small">Applicant</label>
                    <p class="fw-semibold mb-0">@Model.ApplicantName</p>
                </div>
                <div class="col-md-6">
                    <label class="form-label text-muted small">Application #</label>
                    <p class="mb-0">
                        <a asp-area="Admin" asp-controller="LoanApplication" asp-action="Details" asp-route-id="@Model.LoanApplicationId">
                            #@Model.LoanApplicationId
                        </a>
                    </p>
                </div>
                <div class="col-md-6">
                    <label class="form-label text-muted small">Approved Amount</label>
                    <p class="fw-bold text-success fs-5 mb-0">@Model.ApprovedAmount.ToString("C")</p>
                </div>
                <div class="col-md-6">
                    <label class="form-label text-muted small">Current Status</label>
                    <p class="mb-0">
                        @switch (Model.CurrentStatus)
                        {
                            case LoanApp.Models.DisbursementStatus.PendingSetup:
                                <span class="badge bg-secondary fs-6"><i class="bi bi-hourglass me-1"></i>Pending Setup</span>
                                break;
                            case LoanApp.Models.DisbursementStatus.BankSelected:
                                <span class="badge bg-info fs-6"><i class="bi bi-bank me-1"></i>Bank Selected</span>
                                break;
                            case LoanApp.Models.DisbursementStatus.AccountDetailsSubmitted:
                                <span class="badge bg-primary fs-6"><i class="bi bi-credit-card me-1"></i>Details Submitted</span>
                                break;
                            case LoanApp.Models.DisbursementStatus.ReadyForPayment:
                                <span class="badge bg-warning text-dark fs-6"><i class="bi bi-cash me-1"></i>Ready for Payment</span>
                                break;
                            case LoanApp.Models.DisbursementStatus.Paid:
                                <span class="badge bg-success fs-6"><i class="bi bi-check-circle me-1"></i>Paid</span>
                                break;
                            case LoanApp.Models.DisbursementStatus.Failed:
                                <span class="badge bg-danger fs-6"><i class="bi bi-x-circle me-1"></i>Failed</span>
                                break;
                        }
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Bank Details Card -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-white">
            <h5 class="fw-bold mb-0"><i class="bi bi-bank2 me-2"></i>Bank Details</h5>
        </div>
        <div class="card-body">
            @if (Model.BankName != null)
            {
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label text-muted small">Bank</label>
                        <p class="fw-semibold mb-0">@Model.BankName</p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-muted small">Account Name</label>
                        <p class="fw-semibold mb-0">@(Model.AccountName ?? "—")</p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-muted small">Account Number</label>
                        <p class="fw-semibold mb-0">@(Model.AccountNumber ?? "—")</p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-muted small">Sort Code</label>
                        <p class="fw-semibold mb-0">@(Model.SortCode ?? "—")</p>
                    </div>
                </div>
            }
            else
            {
                <p class="text-muted mb-0"><i class="bi bi-info-circle me-1"></i>Bank details not yet provided by the applicant.</p>
            }
        </div>
    </div>

    <!-- Payment Info (if paid) -->
    @if (Model.CurrentStatus == LoanApp.Models.DisbursementStatus.Paid)
    {
        <div class="card shadow-sm mb-4 border-success">
            <div class="card-header bg-success text-white">
                <h5 class="fw-bold mb-0"><i class="bi bi-check-circle me-2"></i>Payment Information</h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label text-muted small">Paid Amount</label>
                        <p class="fw-bold text-success fs-5 mb-0">@(Model.PaidAmount?.ToString("C") ?? "—")</p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-muted small">Payment Reference</label>
                        <p class="fw-semibold mb-0">@(Model.PaymentReference ?? "—")</p>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(Model.Notes))
                {
                    <div class="mt-3">
                        <label class="form-label text-muted small">Notes</label>
                        <p class="mb-0">@Model.Notes</p>
                    </div>
                }
            </div>
        </div>
    }

    <!-- Update Status Form (only for actionable statuses) -->
    @if (Model.CurrentStatus != LoanApp.Models.DisbursementStatus.Paid && Model.CurrentStatus != LoanApp.Models.DisbursementStatus.Failed && Model.CurrentStatus != LoanApp.Models.DisbursementStatus.PendingSetup && Model.CurrentStatus != LoanApp.Models.DisbursementStatus.BankSelected)
    {
        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <h5 class="fw-bold mb-0"><i class="bi bi-arrow-repeat me-2"></i>Update Status</h5>
            </div>
            <div class="card-body">
                <form asp-action="UpdateStatus" method="post">
                    <input type="hidden" asp-for="DisbursementId" />
                    <input type="hidden" asp-for="LoanApplicationId" />

                    <div class="mb-3">
                        <label asp-for="NewStatus" class="form-label fw-semibold">New Status</label>
                        <select asp-for="NewStatus" class="form-select" id="statusSelect">
                            @if (Model.CurrentStatus == LoanApp.Models.DisbursementStatus.AccountDetailsSubmitted)
                            {
                                <option value="@((int)LoanApp.Models.DisbursementStatus.ReadyForPayment)">Ready for Payment</option>
                                <option value="@((int)LoanApp.Models.DisbursementStatus.Failed)">Failed</option>
                            }
                            else if (Model.CurrentStatus == LoanApp.Models.DisbursementStatus.ReadyForPayment)
                            {
                                <option value="@((int)LoanApp.Models.DisbursementStatus.Paid)">Paid Successfully</option>
                                <option value="@((int)LoanApp.Models.DisbursementStatus.Failed)">Failed</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3" id="paidAmountGroup" style="display:none;">
                        <label asp-for="PaidAmount" class="form-label fw-semibold">Paid Amount</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="PaidAmount" class="form-control" step="0.01" value="@Model.ApprovedAmount" />
                        </div>
                        <span asp-validation-for="PaidAmount" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Notes" class="form-label fw-semibold">Notes</label>
                        <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Optional notes about this status change"></textarea>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Update Status</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>

                @if (User.IsInRole("GlobalAdmin"))
                {
                    <hr class="my-3" />
                    <form asp-action="Delete" method="post">
                        <input type="hidden" name="id" value="@Model.DisbursementId" />
                        <button type="submit" class="btn btn-outline-danger w-100"
                                onclick="return confirm('PERMANENT DELETE: This will delete the disbursement, associated loan, and all repayment records. This cannot be undone. Continue?')">
                            <i class="bi bi-trash3 me-1"></i>Delete Disbursement
                        </button>
                    </form>
                }
            </div>
        </div>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            function togglePaidFields() {
                var val = $('#statusSelect').val();
                // DisbursementStatus.Paid = 4
                if (val == '@((int)LoanApp.Models.DisbursementStatus.Paid)') {
                    $('#paidAmountGroup, #paymentRefGroup').show();
                } else {
                    $('#paidAmountGroup, #paymentRefGroup').hide();
                }
            }
            $('#statusSelect').on('change', togglePaidFields);
            togglePaidFields();
        });
    </script>
}
