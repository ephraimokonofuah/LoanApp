@model IEnumerable<LoanApp.Models.CryptoWallet>

@{
    ViewData["Title"] = "Crypto Wallets";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-1">
                <i class="bi bi-wallet2 text-primary me-2"></i>Crypto Wallets
            </h3>
            <p class="text-muted mb-0">Manage USDT and Bitcoin wallets used for repayment collection.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>Add Wallet
        </a>
    </div>

    @if (TempData["success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-1"></i> @TempData["success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <i class="bi bi-wallet2 text-muted" style="font-size: 4rem;"></i>
                <h5 class="mt-3 text-muted">No Wallets Added</h5>
                <p class="text-muted">Add USDT or Bitcoin wallets so admins can send payment details to users.</p>
                <a asp-action="Create" class="btn btn-primary">
                    <i class="bi bi-plus-circle me-1"></i>Add First Wallet
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var wallet in Model)
            {
                var typeInfo = wallet.WalletType switch
                {
                    PaymentMethodType.USDT => ("bi-currency-exchange", "USDT (Tether)", "success"),
                    PaymentMethodType.Bitcoin => ("bi-currency-bitcoin", "Bitcoin", "warning"),
                    _ => ("bi-wallet2", wallet.WalletType.ToString(), "secondary")
                };

                <div class="col-md-6 col-xl-4">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                            <div>
                                <span class="badge bg-@typeInfo.Item3 me-2">
                                    <i class="bi @typeInfo.Item1 me-1"></i>@typeInfo.Item2
                                </span>
                                @if (wallet.IsActive)
                                {
                                    <span class="badge bg-success-subtle text-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger-subtle text-danger">Inactive</span>
                                }
                            </div>
                        </div>
                        <div class="card-body">
                            @if (!string.IsNullOrEmpty(wallet.Label))
                            {
                                <h6 class="fw-bold mb-2">@wallet.Label</h6>
                            }
                            <div class="mb-2">
                                <small class="text-muted d-block">Wallet Address</small>
                                <code class="text-break">@wallet.WalletAddress</code>
                            </div>
                            @if (!string.IsNullOrEmpty(wallet.Network))
                            {
                                <div class="mb-2">
                                    <small class="text-muted d-block">Network</small>
                                    <span class="fw-bold">@wallet.Network</span>
                                </div>
                            }
                            <div>
                                <small class="text-muted">Added @wallet.CreatedAt.ToString("dd MMM yyyy")</small>
                                @if (wallet.UpdatedAt.HasValue)
                                {
                                    <small class="text-muted"> &bull; Updated @wallet.UpdatedAt.Value.ToString("dd MMM yyyy")</small>
                                }
                            </div>
                        </div>
                        <div class="card-footer bg-white border-top-0 d-flex gap-2">
                            <a asp-action="Edit" asp-route-id="@wallet.Id" class="btn btn-outline-primary btn-sm flex-fill">
                                <i class="bi bi-pencil me-1"></i>Edit
                            </a>
                            <form asp-action="Delete" method="post" class="flex-fill">
                                <input type="hidden" name="id" value="@wallet.Id" />
                                <button type="submit" class="btn btn-outline-danger btn-sm w-100"
                                        onclick="return confirm('Delete this wallet?')">
                                    <i class="bi bi-trash3 me-1"></i>Delete
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
