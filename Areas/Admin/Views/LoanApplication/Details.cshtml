@model LoanApp.Models.LoanApplication

@{
    ViewData["Title"] = "Loan Application Details";
    var documents = ViewBag.Documents as List<LoanApp.Models.Document> ?? new List<LoanApp.Models.Document>();
}

<div class="container-fluid mt-4">
    <!-- Back Button -->
    <a asp-area="Admin" asp-controller="LoanApplication" asp-action="Index" class="btn btn-outline-secondary mb-3">
        <i class="bi bi-arrow-left me-1"></i> Back to Dashboard
    </a>

    <div class="row g-4">
        <!-- Left Column: Application Info -->
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-dark text-white py-3">
                    <h5 class="mb-0"><i class="bi bi-file-earmark-text me-2"></i>Application #@Model.Id</h5>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-5 text-muted">Applicant ID</dt>
                        <dd class="col-sm-7 fw-semibold">@Model.UserId</dd>

                        <dt class="col-sm-5 text-muted">Loan Amount</dt>
                        <dd class="col-sm-7 fw-bold text-primary fs-5">@Model.LoanAmount.ToString("C")</dd>

                        <dt class="col-sm-5 text-muted">Purpose</dt>
                        <dd class="col-sm-7">@Model.LoanPurpose</dd>

                        <dt class="col-sm-5 text-muted">Duration</dt>
                        <dd class="col-sm-7">@Model.DurationMonths months</dd>

                        <dt class="col-sm-5 text-muted">Interest Rate</dt>
                        <dd class="col-sm-7">@Model.InterestRate%</dd>

                        <dt class="col-sm-5 text-muted">Applied On</dt>
                        <dd class="col-sm-7">@Model.CreatedAt.ToString("dd MMM yyyy, HH:mm")</dd>

                        <dt class="col-sm-5 text-muted">Status</dt>
                        <dd class="col-sm-7">
                            @if (Model.Status == "Pending")
                            {
                                <span class="badge bg-warning text-dark fs-6"><i class="bi bi-hourglass-split me-1"></i>Pending</span>
                            }
                            else if (Model.Status == "Documents Requested")
                            {
                                <span class="badge bg-info fs-6"><i class="bi bi-file-earmark-arrow-up me-1"></i>Documents Requested</span>
                            }
                            else if (Model.Status == "Approved")
                            {
                                <span class="badge bg-success fs-6"><i class="bi bi-check-circle me-1"></i>Approved</span>
                            }
                            else if (Model.Status == "Rejected")
                            {
                                <span class="badge bg-danger fs-6"><i class="bi bi-x-circle me-1"></i>Rejected</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary fs-6">@Model.Status</span>
                            }
                        </dd>
                    </dl>
                </div>
            </div>

            <!-- Application Actions -->
            <div class="card border-0 shadow-sm mt-3">
                <div class="card-header bg-white py-3">
                    <h6 class="fw-bold mb-0"><i class="bi bi-calculator me-2 text-primary"></i>Repayment Breakdown</h6>
                </div>
                <div class="card-body">
                    @{
                        var repayment = LoanApp.Utility.LoanCalculator.Calculate(Model.LoanAmount, Model.InterestRate, Model.DurationMonths);
                        var monthlyPayment = repayment.MonthlyPayment;
                        var totalRepayment = repayment.TotalRepayment;
                        var totalInterest = repayment.TotalInterest;
                        var monthlyRatePercent = Model.InterestRate / 12m;
                    }
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <div class="p-2 bg-light rounded text-center">
                                <div class="text-muted small">Loan Amount</div>
                                <div class="fw-bold">@Model.LoanAmount.ToString("C")</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="p-2 bg-light rounded text-center">
                                <div class="text-muted small">Annual Rate</div>
                                <div class="fw-bold text-primary">@Model.InterestRate% p.a.</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="p-2 bg-light rounded text-center">
                                <div class="text-muted small">Monthly Rate</div>
                                <div class="fw-bold text-info">@monthlyRatePercent.ToString("F4")% p.m.</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="p-2 bg-light rounded text-center">
                                <div class="text-muted small">Duration</div>
                                <div class="fw-bold">@Model.DurationMonths months</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="p-2 bg-light rounded text-center">
                                <div class="text-muted small">Interest Cost</div>
                                <div class="fw-bold text-danger">@totalInterest.ToString("C")</div>
                            </div>
                        </div>
                    </div>
                    <div class="border rounded p-3 mb-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <div class="text-muted small">Monthly Repayment</div>
                                <div class="fs-4 fw-bold text-success">@monthlyPayment.ToString("C")</div>
                            </div>
                            <div class="text-end">
                                <div class="text-muted small">Total Repayment</div>
                                <div class="fs-4 fw-bold text-danger">@totalRepayment.ToString("C")</div>
                                <div class="text-muted small">@Model.DurationMonths &times; @monthlyPayment.ToString("C")</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Application Actions -->
            <div class="card border-0 shadow-sm mt-3">
                <div class="card-header bg-white py-3">
                    <h6 class="fw-bold mb-0"><i class="bi bi-lightning me-2"></i>Actions</h6>
                </div>
                <div class="card-body">
                    <!-- Request Documents -->
                    @if (!Model.DocumentsRequested)
                    {
                        <div class="mb-3 p-3 bg-light rounded">
                            <h6 class="fw-bold text-info"><i class="bi bi-file-earmark-arrow-up me-1"></i> Request Documents</h6>
                            <p class="text-muted small mb-2">Ask the applicant to upload supporting documents before making a decision.</p>
                            <form asp-area="Admin" asp-controller="LoanApplication" asp-action="RequestDocuments" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@Model.Id" />
                                <div class="mb-2">
                                    <textarea name="documentRequestNote" class="form-control form-control-sm" rows="2"
                                              placeholder="e.g. Please upload proof of income, ID, and bank statements..."></textarea>
                                </div>
                                <button type="submit" class="btn btn-info btn-sm text-white">
                                    <i class="bi bi-send me-1"></i> Request Documents
                                </button>
                            </form>
                        </div>
                    }
                    else
                    {
                        <div class="mb-3 p-3 bg-info bg-opacity-10 rounded">
                            <span class="badge bg-info text-white mb-1"><i class="bi bi-check me-1"></i>Documents Requested</span>
                            @if (!string.IsNullOrEmpty(Model.DocumentRequestNote))
                            {
                                <p class="small text-muted mb-0 mt-1"><strong>Note:</strong> @Model.DocumentRequestNote</p>
                            }
                        </div>
                    }

                    <!-- Approve / Reject -->
                    <div class="d-flex gap-2">
                        <form asp-area="Admin" asp-controller="LoanApplication" asp-action="Approve" method="post" class="flex-fill">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-success w-100" @(Model.Status == "Approved" ? "disabled" : "")>
                                <i class="bi bi-check-circle me-1"></i> Approve Application
                            </button>
                        </form>
                        <form asp-area="Admin" asp-controller="LoanApplication" asp-action="Reject" method="post" class="flex-fill">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-danger w-100" @(Model.Status == "Rejected" ? "disabled" : "")>
                                <i class="bi bi-x-circle me-1"></i> Reject Application
                            </button>
                        </form>
                    </div>

                    @if (User.IsInRole("GlobalAdmin"))
                    {
                        <hr class="my-3" />
                        <form asp-area="Admin" asp-controller="LoanApplication" asp-action="Delete" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-outline-danger w-100"
                                    onclick="return confirm('PERMANENT DELETE: This will delete the application, all documents, disbursement, loan, and repayments. This cannot be undone. Continue?')">
                                <i class="bi bi-trash3 me-1"></i> Delete Application
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>

        <!-- Right Column: Documents -->
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0"><i class="bi bi-folder2-open me-2"></i>Submitted Documents</h5>
                    <span class="badge bg-primary rounded-pill">@documents.Count</span>
                </div>
                <div class="card-body p-0">
                    @if (documents.Any())
                    {
                        @foreach (var doc in documents)
                        {
                            <div class="border-bottom p-3">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div class="d-flex align-items-start">
                                        <div class="rounded bg-light d-flex align-items-center justify-content-center me-3" style="width:48px;height:48px;">
                                            @if (doc.MimeType != null && doc.MimeType.Contains("pdf"))
                                            {
                                                <i class="bi bi-file-earmark-pdf text-danger fs-4"></i>
                                            }
                                            else if (doc.MimeType != null && doc.MimeType.Contains("image"))
                                            {
                                                <i class="bi bi-file-earmark-image text-success fs-4"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-file-earmark text-secondary fs-4"></i>
                                            }
                                        </div>
                                        <div>
                                            <h6 class="mb-0 fw-semibold">@doc.DocumentType</h6>
                                            <small class="text-muted">@doc.FileName</small><br />
                                            <small class="text-muted">
                                                @((doc.FileSize / 1024.0).ToString("F1")) KB &middot; Uploaded @doc.UploadedAt.ToString("dd MMM yyyy")
                                            </small>
                                            @if (!string.IsNullOrEmpty(doc.ReviewNotes))
                                            {
                                                <br /><small class="text-muted"><i class="bi bi-chat-text me-1"></i>@doc.ReviewNotes</small>
                                            }
                                        </div>
                                    </div>
                                    <div>
                                        @if (doc.Status == "Pending")
                                        {
                                            <span class="badge bg-warning text-dark mb-2"><i class="bi bi-hourglass-split me-1"></i>Pending Review</span>
                                        }
                                        else if (doc.Status == "Approved")
                                        {
                                            <span class="badge bg-success mb-2"><i class="bi bi-check-circle me-1"></i>Approved</span>
                                        }
                                        else if (doc.Status == "Rejected")
                                        {
                                            <span class="badge bg-danger mb-2"><i class="bi bi-x-circle me-1"></i>Rejected</span>
                                        }
                                    </div>
                                </div>

                                <!-- Document Actions -->
                                <div class="mt-2 d-flex gap-2 flex-wrap align-items-center">
                                    <a href="/Admin/Document/ViewDocument?documentId=@doc.Id" target="_blank" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye me-1"></i>View
                                    </a>
                                    <a href="/Admin/Document/DownloadDocument?documentId=@doc.Id" class="btn btn-sm btn-outline-secondary">
                                        <i class="bi bi-download me-1"></i>Download
                                    </a>

                                    @if (doc.Status == "Pending")
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-success" data-bs-toggle="modal" data-bs-target="#approveDocModal-@doc.Id">
                                            <i class="bi bi-check me-1"></i>Approve
                                        </button>
                                        <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#rejectDocModal-@doc.Id">
                                            <i class="bi bi-x me-1"></i>Reject
                                        </button>
                                    }
                                    else
                                    {
                                        @if (doc.ReviewedAt.HasValue)
                                        {
                                            <small class="text-muted ms-2">
                                                <i class="bi bi-clock me-1"></i>Reviewed @doc.ReviewedAt.Value.ToString("dd MMM yyyy")
                                                @if (!string.IsNullOrEmpty(doc.ReviewedBy))
                                                {
                                                    <text> by @doc.ReviewedBy</text>
                                                }
                                            </small>
                                        }
                                    }
                                </div>
                            </div>

                            <!-- Approve Document Modal -->
                            <div class="modal fade" id="approveDocModal-@doc.Id" tabindex="-1">
                                <div class="modal-dialog">
                                    <div class="modal-content">
                                        <form asp-area="Admin" asp-controller="Document" asp-action="ApproveDocument" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="documentId" value="@doc.Id" />
                                            <div class="modal-header bg-success text-white">
                                                <h6 class="modal-title"><i class="bi bi-check-circle me-1"></i>Approve Document</h6>
                                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                            </div>
                                            <div class="modal-body">
                                                <p>Approve <strong>@doc.DocumentType</strong> — <em>@doc.FileName</em>?</p>
                                                <div class="mb-0">
                                                    <label class="form-label small">Notes (optional)</label>
                                                    <textarea name="reviewNotes" class="form-control form-control-sm" rows="2" placeholder="Add a note..."></textarea>
                                                </div>
                                            </div>
                                            <div class="modal-footer">
                                                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                <button type="submit" class="btn btn-sm btn-success"><i class="bi bi-check me-1"></i>Approve</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>

                            <!-- Reject Document Modal -->
                            <div class="modal fade" id="rejectDocModal-@doc.Id" tabindex="-1">
                                <div class="modal-dialog">
                                    <div class="modal-content">
                                        <form asp-area="Admin" asp-controller="Document" asp-action="RejectDocument" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="documentId" value="@doc.Id" />
                                            <div class="modal-header bg-danger text-white">
                                                <h6 class="modal-title"><i class="bi bi-x-circle me-1"></i>Reject Document</h6>
                                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                            </div>
                                            <div class="modal-body">
                                                <p>Reject <strong>@doc.DocumentType</strong> — <em>@doc.FileName</em>?</p>
                                                <div class="mb-0">
                                                    <label class="form-label small">Reason for rejection</label>
                                                    <textarea name="reviewNotes" class="form-control form-control-sm" rows="2" placeholder="e.g. Document is blurry, expired ID..."></textarea>
                                                </div>
                                            </div>
                                            <div class="modal-footer">
                                                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                <button type="submit" class="btn btn-sm btn-danger"><i class="bi bi-x me-1"></i>Reject</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-folder text-muted" style="font-size:3rem;"></i>
                            <p class="text-muted mt-2 mb-0">
                                @if (Model.DocumentsRequested)
                                {
                                    <text>Documents have been requested. Waiting for the applicant to upload.</text>
                                }
                                else
                                {
                                    <text>No documents requested yet. Use the "Request Documents" button to ask the applicant for supporting documents.</text>
                                }
                            </p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
