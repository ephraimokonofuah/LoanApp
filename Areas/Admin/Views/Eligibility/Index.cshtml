@model List<LoanApp.Models.EligibilityCheck>

@{
    ViewData["Title"] = "Manage Eligibility Checks";
}

<div class="container-fluid mt-4">
    <h3 class="mb-4"><i class="bi bi-clipboard-check me-2"></i>Eligibility Checks Management</h3>

    <!-- Stats Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-3 col-6">
            <div class="card shadow-sm border-0 bg-primary text-white">
                <div class="card-body text-center">
                    <i class="bi bi-clipboard-data fs-3"></i>
                    <h4 class="mt-1 mb-0">@ViewBag.TotalChecks</h4>
                    <small>Total Checks</small>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card shadow-sm border-0 bg-warning text-dark">
                <div class="card-body text-center">
                    <i class="bi bi-hourglass-split fs-3"></i>
                    <h4 class="mt-1 mb-0">@ViewBag.Pending</h4>
                    <small>Pending Review</small>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card shadow-sm border-0 bg-success text-white">
                <div class="card-body text-center">
                    <i class="bi bi-check-circle fs-3"></i>
                    <h4 class="mt-1 mb-0">@ViewBag.Approved</h4>
                    <small>Approved</small>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card shadow-sm border-0 bg-danger text-white">
                <div class="card-body text-center">
                    <i class="bi bi-x-circle fs-3"></i>
                    <h4 class="mt-1 mb-0">@ViewBag.Rejected</h4>
                    <small>Rejected</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Table -->
    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table id="eligibilityTable" class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Applicant</th>
                            <th>Loan Type</th>
                            <th>Amount</th>
                            <th>Duration</th>
                            <th>Eligible</th>
                            <th>Status</th>
                            <th>Date</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>
                                    <div class="fw-bold">@item.FullName</div>
                                    <small class="text-muted">@item.User?.Email</small>
                                </td>
                                <td>@item.LoanType?.Name</td>
                                <td>@item.DesiredLoanAmount.ToString("C")</td>
                                <td>@item.DurationMonths mo</td>
                                <td>
                                    @if (item.IsEligible)
                                    {
                                        <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Eligible</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger"><i class="bi bi-x-circle me-1"></i>Not Eligible</span>
                                    }
                                </td>
                                <td>
                                    @switch (item.Status)
                                    {
                                        case "Approved":
                                            <span class="badge bg-success">Approved</span>
                                            break;
                                        case "Rejected":
                                            <span class="badge bg-danger">Rejected</span>
                                            break;
                                        default:
                                            <span class="badge bg-warning text-dark">Pending</span>
                                            break;
                                    }
                                </td>
                                <td>@item.CreatedAt.ToString("dd MMM yyyy")</td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye me-1"></i>Review
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#eligibilityTable').DataTable({
                order: [[0, 'desc']]
            });
        });
    </script>
}
