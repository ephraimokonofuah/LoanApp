@model List<LoanApp.Models.Bank>

@{
    ViewData["Title"] = "Manage Banks";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1"><i class="bi bi-bank2 text-primary me-2"></i>Manage Banks</h2>
            <p class="text-muted mb-0">Create, edit, and manage banks for loan disbursements.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i> Add Bank
        </a>
    </div>

    @if (TempData["success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-1"></i> @TempData["success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle me-1"></i> @TempData["error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        @foreach (var bank in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card shadow-sm h-100 @(bank.IsActive ? "" : "border-secondary opacity-75")">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title fw-bold mb-0">@bank.Name</h5>
                            @if (bank.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </div>
                        <div class="d-flex align-items-center mb-3">
                            <i class="bi bi-building text-primary me-2 fs-4"></i>
                            <div>
                                <span class="fs-5 fw-bold text-primary">@bank.Code</span>
                                <br /><small class="text-muted">Bank Code</small>
                            </div>
                        </div>
                        <small class="text-muted">Added: @bank.CreatedAt.ToString("dd MMM yyyy")</small>
                    </div>
                    <div class="card-footer bg-transparent d-flex gap-2">
                        <a asp-action="Edit" asp-route-id="@bank.Id" class="btn btn-sm btn-outline-primary flex-fill">
                            <i class="bi bi-pencil me-1"></i> Edit
                        </a>
                        <form asp-action="ToggleActive" asp-route-id="@bank.Id" method="post" class="flex-fill">
                            @Html.AntiForgeryToken()
                            @if (bank.IsActive)
                            {
                                <button type="submit" class="btn btn-sm btn-outline-warning w-100">
                                    <i class="bi bi-pause-circle me-1"></i> Deactivate
                                </button>
                            }
                            else
                            {
                                <button type="submit" class="btn btn-sm btn-outline-success w-100">
                                    <i class="bi bi-play-circle me-1"></i> Activate
                                </button>
                            }
                        </form>
                        <form asp-action="Delete" asp-route-id="@bank.Id" method="post" class="flex-fill"
                              onsubmit="return confirm('Are you sure you want to delete this bank?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger w-100">
                                <i class="bi bi-trash me-1"></i> Delete
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }

        @if (!Model.Any())
        {
            <div class="col-12">
                <div class="text-center py-5">
                    <i class="bi bi-bank2 text-muted" style="font-size:3rem;"></i>
                    <p class="text-muted mt-2">No banks configured yet. Add your first bank to get started.</p>
                </div>
            </div>
        }
    </div>
</div>
