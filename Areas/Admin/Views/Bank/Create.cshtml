@model LoanApp.Models.Bank

@{
    ViewData["Title"] = "Add Bank";
}

<div class="container mt-4" style="max-width: 600px;">
    <h2 class="fw-bold mb-4"><i class="bi bi-plus-circle text-primary me-2"></i>Add Bank</h2>

    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="Create" method="post">
                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-semibold">Bank Name</label>
                    <input asp-for="Name" class="form-control" placeholder="e.g., Barclays" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Code" class="form-label fw-semibold">Bank Code</label>
                    <input asp-for="Code" class="form-control" placeholder="e.g., BARC" />
                    <span asp-validation-for="Code" class="text-danger"></span>
                </div>
                <div class="mb-3 form-check">
                    <input asp-for="IsActive" class="form-check-input" />
                    <label asp-for="IsActive" class="form-check-label">Active</label>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Create</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
