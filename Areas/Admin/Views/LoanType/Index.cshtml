@model List<LoanApp.Models.LoanType>

@{
    ViewData["Title"] = "Manage Loan Types";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1"><i class="bi bi-tags-fill text-primary me-2"></i>Manage Loan Types</h2>
            <p class="text-muted mb-0">Create, edit, and manage loan types and their interest rates.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i> Add Loan Type
        </a>
    </div>

    @if (TempData["success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-1"></i> @TempData["success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle me-1"></i> @TempData["error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        @foreach (var loanType in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card shadow-sm h-100 @(loanType.IsActive ? "" : "border-secondary opacity-75")">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title fw-bold mb-0">@loanType.Name</h5>
                            @if (loanType.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </div>
                        <p class="card-text text-muted small">@(loanType.Description ?? "No description")</p>
                        <div class="d-flex align-items-center mb-3">
                            <i class="bi bi-percent text-primary me-2 fs-4"></i>
                            <div>
                                <span class="fs-3 fw-bold text-primary">@loanType.InterestRate%</span>
                                <br /><small class="text-muted">Annual Interest Rate</small>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent d-flex gap-2">
                        <a asp-action="Edit" asp-route-id="@loanType.Id" class="btn btn-sm btn-outline-primary flex-fill">
                            <i class="bi bi-pencil me-1"></i> Edit
                        </a>
                        <form asp-action="ToggleActive" asp-route-id="@loanType.Id" method="post" class="flex-fill">
                            @Html.AntiForgeryToken()
                            @if (loanType.IsActive)
                            {
                                <button type="submit" class="btn btn-sm btn-outline-warning w-100">
                                    <i class="bi bi-pause-circle me-1"></i> Deactivate
                                </button>
                            }
                            else
                            {
                                <button type="submit" class="btn btn-sm btn-outline-success w-100">
                                    <i class="bi bi-play-circle me-1"></i> Activate
                                </button>
                            }
                        </form>
                        <form asp-action="Delete" asp-route-id="@loanType.Id" method="post" class="flex-fill"
                              onsubmit="return confirm('Are you sure you want to delete this loan type?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger w-100">
                                <i class="bi bi-trash me-1"></i> Delete
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-inbox display-1 text-muted"></i>
            <p class="text-muted mt-3">No loan types found. Click "Add Loan Type" to create one.</p>
        </div>
    }
</div>
