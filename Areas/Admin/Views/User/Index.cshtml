@model List<LoanApp.Areas.Admin.Controllers.UserViewModel>

@{
    ViewData["Title"] = "User Management";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1"><i class="bi bi-people text-primary me-2"></i>User Management</h2>
            <p class="text-muted mb-0">Manage user accounts, roles, and access permissions.</p>
        </div>
    </div>

    @if (TempData["success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-1"></i> @TempData["success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle me-1"></i> @TempData["error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Stats Cards -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="mb-2"><i class="bi bi-people-fill text-primary" style="font-size: 1.5rem;"></i></div>
                    <h4 class="fw-bold mb-0">@ViewBag.TotalUsers</h4>
                    <small class="text-muted">Total Users</small>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="mb-2"><i class="bi bi-person-check-fill text-success" style="font-size: 1.5rem;"></i></div>
                    <h4 class="fw-bold text-success mb-0">@ViewBag.ActiveUsers</h4>
                    <small class="text-muted">Active</small>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="mb-2"><i class="bi bi-person-slash text-danger" style="font-size: 1.5rem;"></i></div>
                    <h4 class="fw-bold text-danger mb-0">@ViewBag.BannedUsers</h4>
                    <small class="text-muted">Banned</small>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="mb-2"><i class="bi bi-shield-fill-check text-info" style="font-size: 1.5rem;"></i></div>
                    <h4 class="fw-bold text-info mb-0">@ViewBag.AdminUsers</h4>
                    <small class="text-muted">Admins</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Users Table -->
    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
            <table id="usersTable" class="table table-hover align-middle" style="width:100%">
                <thead class="table-light">
                    <tr>
                        <th>User</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Applications</th>
                        <th>Status</th>
                        <th>Joined</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="rounded-circle bg-@(user.Roles.Contains("Admin") ? "primary" : "secondary") bg-opacity-10 d-flex align-items-center justify-content-center me-2" style="width: 36px; height: 36px;">
                                        <i class="bi bi-@(user.Roles.Contains("Admin") ? "shield-lock" : "person") text-@(user.Roles.Contains("Admin") ? "primary" : "secondary")"></i>
                                    </div>
                                    <div>
                                        <span class="fw-semibold">@user.FullName</span>
                                        @if (user.IsCurrentUser)
                                        {
                                            <span class="badge bg-primary bg-opacity-10 text-primary ms-1" style="font-size: 0.65rem;">You</span>
                                        }
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="text-muted">@user.Email</span>
                                @if (!user.EmailConfirmed)
                                {
                                    <i class="bi bi-exclamation-triangle-fill text-warning ms-1" title="Email not confirmed" data-bs-toggle="tooltip"></i>
                                }
                            </td>
                            <td>
                                @foreach (var role in user.Roles)
                                {
                                    <span class="badge bg-@(role == "Admin" ? "danger" : "primary") bg-opacity-75">@role</span>
                                }
                            </td>
                            <td><span class="badge bg-light text-dark">@user.ApplicationCount</span></td>
                            <td>
                                @if (user.IsBanned)
                                {
                                    <span class="badge bg-danger"><i class="bi bi-slash-circle me-1"></i>Banned</span>
                                }
                                else
                                {
                                    <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Active</span>
                                }
                            </td>
                            <td><small class="text-muted">@user.CreatedAt.ToString("dd MMM yyyy")</small></td>
                            <td>
                                <a asp-action="Details" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary" title="View Details">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#usersTable').DataTable({
                "order": [[5, "desc"]],
                "language": {
                    "emptyTable": "No users found"
                }
            });

            // Initialize tooltips
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            tooltipTriggerList.map(function (el) { return new bootstrap.Tooltip(el); });
        });
    </script>
}
