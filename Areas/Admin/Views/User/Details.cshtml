@model LoanApp.Areas.Admin.Controllers.UserDetailsViewModel

@{
    ViewData["Title"] = "User Details — " + Model.FullName;
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">
                <i class="bi bi-person-badge text-primary me-2"></i>@Model.FullName
                @if (Model.IsCurrentUser)
                {
                    <span class="badge bg-primary bg-opacity-10 text-primary ms-2" style="font-size: 0.6rem; vertical-align: middle;">You</span>
                }
            </h2>
            <p class="text-muted mb-0">View and manage this user's account settings and activity.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back to Users
        </a>
    </div>

    @if (TempData["success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-1"></i> @TempData["success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle me-1"></i> @TempData["error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["info"] != null)
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            <i class="bi bi-info-circle me-1"></i> @TempData["info"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Ban Alert -->
    @if (Model.IsBanned)
    {
        <div class="alert alert-danger border-0 shadow-sm d-flex align-items-start" role="alert">
            <i class="bi bi-slash-circle-fill fs-4 me-3 mt-1"></i>
            <div>
                <h6 class="alert-heading fw-bold mb-1">Account Banned</h6>
                <p class="mb-1">This user was banned on <strong>@Model.BannedAt?.ToString("dd MMM yyyy, HH:mm")</strong></p>
                @if (!string.IsNullOrEmpty(Model.BanReason))
                {
                    <p class="mb-0"><strong>Reason:</strong> @Model.BanReason</p>
                }
            </div>
        </div>
    }

    <div class="row g-4">
        <!-- Left Column: User Info + Actions -->
        <div class="col-lg-4">
            <!-- Profile Card -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body text-center pt-4">
                    <div class="rounded-circle bg-@(Model.Roles.Contains("Admin") ? "primary" : "secondary") bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                        <i class="bi bi-@(Model.Roles.Contains("Admin") ? "shield-lock" : "person-fill") text-@(Model.Roles.Contains("Admin") ? "primary" : "secondary")" style="font-size: 2rem;"></i>
                    </div>
                    <h5 class="fw-bold mb-1">@Model.FullName</h5>
                    <p class="text-muted small mb-2">@Model.Email</p>
                    <div class="mb-3">
                        @foreach (var role in Model.Roles)
                        {
                            <span class="badge bg-@(role == "Admin" ? "danger" : "primary") px-3 py-2">
                                <i class="bi bi-@(role == "Admin" ? "shield-lock" : "person") me-1"></i>@role
                            </span>
                        }
                        @if (Model.IsBanned)
                        {
                            <span class="badge bg-danger px-3 py-2 ms-1">
                                <i class="bi bi-slash-circle me-1"></i>Banned
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-success px-3 py-2 ms-1">
                                <i class="bi bi-check-circle me-1"></i>Active
                            </span>
                        }
                    </div>
                </div>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item d-flex justify-content-between">
                        <span class="text-muted"><i class="bi bi-telephone me-2"></i>Phone</span>
                        <span class="fw-semibold">@(Model.PhoneNumber ?? "Not set")</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        <span class="text-muted"><i class="bi bi-geo-alt me-2"></i>Address</span>
                        <span class="fw-semibold">@(Model.Address ?? "Not set")</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        <span class="text-muted"><i class="bi bi-globe me-2"></i>Country</span>
                        <span class="fw-semibold">@(Model.Country ?? "Not set")</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        <span class="text-muted"><i class="bi bi-mailbox me-2"></i>Post Code</span>
                        <span class="fw-semibold">@(Model.PostCode ?? "Not set")</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        <span class="text-muted"><i class="bi bi-envelope-check me-2"></i>Email Confirmed</span>
                        @if (Model.EmailConfirmed)
                        {
                            <span class="badge bg-success">Yes</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">No</span>
                        }
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        <span class="text-muted"><i class="bi bi-calendar-event me-2"></i>Joined</span>
                        <span class="fw-semibold">@Model.CreatedAt.ToString("dd MMM yyyy")</span>
                    </li>
                </ul>
            </div>

            <!-- Quick Actions Card -->
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white py-3">
                    <h6 class="fw-bold mb-0"><i class="bi bi-lightning-charge me-2"></i>Quick Actions</h6>
                </div>
                <div class="card-body">
                    @if (!Model.IsCurrentUser)
                    {
                        <!-- Ban / Activate (hidden from regular Admins viewing a GlobalAdmin) -->
                        @if (!(Model.Roles.Contains("GlobalAdmin") && !User.IsInRole("GlobalAdmin")))
                        {
                            @if (Model.IsBanned)
                            {
                                <form asp-action="Activate" method="post" class="mb-3">
                                    <input type="hidden" name="id" value="@Model.Id" />
                                    <button type="submit" class="btn btn-success w-100">
                                        <i class="bi bi-person-check me-2"></i>Activate Account
                                    </button>
                                </form>
                            }
                            else
                            {
                                <button type="button" class="btn btn-danger w-100 mb-3" data-bs-toggle="modal" data-bs-target="#banModal">
                                    <i class="bi bi-person-slash me-2"></i>Ban User
                                </button>
                            }
                        }

                        <!-- Role Management -->
                        @if (Model.Roles.Contains("GlobalAdmin"))
                        {
                            @if (User.IsInRole("GlobalAdmin"))
                            {
                                <form asp-action="DemoteFromAdmin" method="post" class="mb-3">
                                    <input type="hidden" name="id" value="@Model.Id" />
                                    <button type="submit" class="btn btn-outline-warning w-100"
                                            onclick="return confirm('Are you sure you want to demote this Global Admin to User?')">
                                        <i class="bi bi-arrow-down-circle me-2"></i>Demote to User
                                    </button>
                                </form>
                            }
                            else
                            {
                                <div class="text-center text-muted py-2 mb-3">
                                    <i class="bi bi-shield-fill-check me-1"></i>
                                    <small>Global Admin — cannot be managed by regular admins.</small>
                                </div>
                            }
                        }
                        else if (Model.Roles.Contains("Admin"))
                        {
                            <form asp-action="DemoteFromAdmin" method="post" class="mb-3">
                                <input type="hidden" name="id" value="@Model.Id" />
                                <button type="submit" class="btn btn-outline-warning w-100"
                                        onclick="return confirm('Are you sure you want to remove admin privileges from this user?')">
                                    <i class="bi bi-arrow-down-circle me-2"></i>Demote to User
                                </button>
                            </form>
                            @if (User.IsInRole("GlobalAdmin"))
                            {
                                <form asp-action="PromoteToGlobalAdmin" method="post" class="mb-3">
                                    <input type="hidden" name="id" value="@Model.Id" />
                                    <button type="submit" class="btn btn-outline-dark w-100"
                                            onclick="return confirm('Are you sure you want to promote this Admin to Global Admin?')">
                                        <i class="bi bi-shield-fill-check me-2"></i>Promote to Global Admin
                                    </button>
                                </form>
                            }
                        }
                        else
                        {
                            <form asp-action="PromoteToAdmin" method="post" class="mb-3">
                                <input type="hidden" name="id" value="@Model.Id" />
                                <button type="submit" class="btn btn-outline-primary w-100"
                                        onclick="return confirm('Are you sure you want to promote this user to Admin?')">
                                    <i class="bi bi-arrow-up-circle me-2"></i>Promote to Admin
                                </button>
                            </form>
                            @if (User.IsInRole("GlobalAdmin"))
                            {
                                <form asp-action="PromoteToGlobalAdmin" method="post" class="mb-3">
                                    <input type="hidden" name="id" value="@Model.Id" />
                                    <button type="submit" class="btn btn-outline-dark w-100"
                                            onclick="return confirm('Are you sure you want to promote this user to Global Admin?')">
                                        <i class="bi bi-shield-fill-check me-2"></i>Promote to Global Admin
                                    </button>
                                </form>
                            }
                        }

                        <!-- Email Confirmation -->
                        @if (!Model.EmailConfirmed)
                        {
                            <form asp-action="ConfirmEmail" method="post" class="mb-3">
                                <input type="hidden" name="id" value="@Model.Id" />
                                <button type="submit" class="btn btn-outline-info w-100">
                                    <i class="bi bi-envelope-check me-2"></i>Confirm Email
                                </button>
                            </form>
                        }

                        <!-- Password Reset -->
                        <form asp-action="ResetPassword" method="post">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-outline-secondary w-100"
                                    onclick="return confirm('This will generate a new temporary password for the user. Continue?')">
                                <i class="bi bi-key me-2"></i>Reset Password
                            </button>
                        </form>

                        <!-- Delete User (GlobalAdmin Only) -->
                        @if (User.IsInRole("GlobalAdmin") && !Model.Roles.Contains("GlobalAdmin"))
                        {
                            <hr class="my-3" />
                            <button type="button" class="btn btn-outline-danger w-100" data-bs-toggle="modal" data-bs-target="#deleteUserModal">
                                <i class="bi bi-trash3 me-2"></i>Delete User Permanently
                            </button>
                        }
                    }
                    else
                    {
                        <div class="text-center text-muted py-3">
                            <i class="bi bi-info-circle fs-4 d-block mb-2"></i>
                            <small>Actions are disabled for your own account.</small>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Right Column: Activity -->
        <div class="col-lg-8">
            <!-- Activity Summary -->
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body text-center">
                            <i class="bi bi-file-earmark-text text-primary" style="font-size: 1.5rem;"></i>
                            <h3 class="fw-bold mt-2 mb-0">@Model.Applications.Count</h3>
                            <small class="text-muted">Applications</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body text-center">
                            <i class="bi bi-clipboard-check text-info" style="font-size: 1.5rem;"></i>
                            <h3 class="fw-bold mt-2 mb-0">@Model.EligibilityChecks.Count</h3>
                            <small class="text-muted">Eligibility Checks</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body text-center">
                            <i class="bi bi-cash-stack text-success" style="font-size: 1.5rem;"></i>
                            <h3 class="fw-bold mt-2 mb-0">@Model.Disbursements.Count</h3>
                            <small class="text-muted">Disbursements</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Loan Applications -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h6 class="fw-bold mb-0"><i class="bi bi-file-earmark-text text-primary me-2"></i>Loan Applications</h6>
                    <span class="badge bg-primary rounded-pill">@Model.Applications.Count</span>
                </div>
                <div class="card-body p-0">
                    @if (Model.Applications.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>ID</th>
                                        <th>Amount</th>
                                        <th>Purpose</th>
                                        <th>Duration</th>
                                        <th>Status</th>
                                        <th>Date</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var app in Model.Applications.OrderByDescending(a => a.CreatedAt))
                                    {
                                        var statusClass = app.Status switch
                                        {
                                            "Approved" => "success",
                                            "Rejected" => "danger",
                                            "Documents Requested" => "info",
                                            _ => "warning"
                                        };
                                        <tr>
                                            <td><span class="fw-semibold">#@app.Id</span></td>
                                            <td>$@app.LoanAmount.ToString("N2")</td>
                                            <td>@app.LoanPurpose</td>
                                            <td>@app.DurationMonths months</td>
                                            <td><span class="badge bg-@statusClass">@app.Status</span></td>
                                            <td><small class="text-muted">@app.CreatedAt.ToString("dd MMM yyyy")</small></td>
                                            <td>
                                                <a asp-area="Admin" asp-controller="LoanApplication" asp-action="Details" asp-route-id="@app.Id"
                                                   class="btn btn-sm btn-outline-primary"><i class="bi bi-eye"></i></a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-4">
                            <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                            No loan applications found.
                        </div>
                    }
                </div>
            </div>

            <!-- Eligibility Checks -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h6 class="fw-bold mb-0"><i class="bi bi-clipboard-check text-info me-2"></i>Eligibility Checks</h6>
                    <span class="badge bg-info rounded-pill">@Model.EligibilityChecks.Count</span>
                </div>
                <div class="card-body p-0">
                    @if (Model.EligibilityChecks.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>ID</th>
                                        <th>Amount</th>
                                        <th>Eligible</th>
                                        <th>Status</th>
                                        <th>Date</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var check in Model.EligibilityChecks.OrderByDescending(c => c.CreatedAt))
                                    {
                                        var checkStatusClass = check.Status switch
                                        {
                                            "Approved" => "success",
                                            "Rejected" => "danger",
                                            _ => "warning"
                                        };
                                        <tr>
                                            <td><span class="fw-semibold">#@check.Id</span></td>
                                            <td>$@check.DesiredLoanAmount.ToString("N2")</td>
                                            <td>
                                                @if (check.IsEligible)
                                                {
                                                    <span class="badge bg-success">Eligible</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger">Not Eligible</span>
                                                }
                                            </td>
                                            <td><span class="badge bg-@checkStatusClass">@check.Status</span></td>
                                            <td><small class="text-muted">@check.CreatedAt.ToString("dd MMM yyyy")</small></td>
                                            <td>
                                                <a asp-area="Admin" asp-controller="Eligibility" asp-action="Details" asp-route-id="@check.Id"
                                                   class="btn btn-sm btn-outline-info"><i class="bi bi-eye"></i></a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-4">
                            <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                            No eligibility checks found.
                        </div>
                    }
                </div>
            </div>

            <!-- Disbursements -->
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h6 class="fw-bold mb-0"><i class="bi bi-cash-stack text-success me-2"></i>Disbursements</h6>
                    <span class="badge bg-success rounded-pill">@Model.Disbursements.Count</span>
                </div>
                <div class="card-body p-0">
                    @if (Model.Disbursements.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>ID</th>
                                        <th>Amount</th>
                                        <th>Bank</th>
                                        <th>Status</th>
                                        <th>Reference</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var d in Model.Disbursements.OrderByDescending(d => d.CreatedAt))
                                    {
                                        var dStatusClass = d.Status switch
                                        {
                                            LoanApp.Models.DisbursementStatus.Paid => "success",
                                            LoanApp.Models.DisbursementStatus.Failed => "danger",
                                            LoanApp.Models.DisbursementStatus.ReadyForPayment => "info",
                                            _ => "warning"
                                        };
                                        <tr>
                                            <td><span class="fw-semibold">#@d.Id</span></td>
                                            <td>$@d.ApprovedAmount.ToString("N2")</td>
                                            <td>@(d.Bank?.Name ?? "Not selected")</td>
                                            <td><span class="badge bg-@dStatusClass">@d.Status</span></td>
                                            <td><code>@(d.PaymentReference ?? "—")</code></td>
                                            <td>
                                                <a asp-area="Admin" asp-controller="Disbursement" asp-action="Details" asp-route-id="@d.Id"
                                                   class="btn btn-sm btn-outline-success"><i class="bi bi-eye"></i></a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-4">
                            <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                            No disbursements found.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Ban Modal -->
@if (!Model.IsCurrentUser && !Model.IsBanned)
{
    <div class="modal fade" id="banModal" tabindex="-1" aria-labelledby="banModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title" id="banModalLabel"><i class="bi bi-person-slash me-2"></i>Ban User</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form asp-action="Ban" method="post">
                    <div class="modal-body">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <div class="alert alert-warning border-0">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            You are about to ban <strong>@Model.FullName</strong>. This will prevent them from logging in.
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Reason for ban</label>
                            <textarea name="banReason" class="form-control" rows="3" placeholder="Enter the reason for banning this user..." required></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-slash-circle me-1"></i>Ban User
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

<!-- Delete User Modal -->
@if (!Model.IsCurrentUser && User.IsInRole("GlobalAdmin") && !Model.Roles.Contains("GlobalAdmin"))
{
    <div class="modal fade" id="deleteUserModal" tabindex="-1" aria-labelledby="deleteUserModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title" id="deleteUserModalLabel"><i class="bi bi-trash3 me-2"></i>Delete User Permanently</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form asp-action="DeleteUser" method="post">
                    <div class="modal-body">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <div class="alert alert-danger border-0">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            <strong>Warning:</strong> This action is irreversible!
                        </div>
                        <p>You are about to permanently delete <strong>@Model.FullName</strong> and <strong>all related records</strong> including:</p>
                        <ul class="text-danger">
                            <li>All loan applications &amp; documents</li>
                            <li>All loans &amp; repayment records</li>
                            <li>All disbursement records</li>
                            <li>All eligibility checks</li>
                            <li>All support tickets &amp; messages</li>
                        </ul>
                        <p class="fw-bold text-danger mb-0">This cannot be undone.</p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash3 me-1"></i>Delete Permanently
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}
