@model LoanApp.Models.Repayment

@{
    ViewData["Title"] = $"Repayment #{Model.InstallmentNumber} - {Model.User?.FullName}";

    var statusBadge = Model.Status switch
    {
        RepaymentStatus.Paid => ("bg-success", "bi-check-circle", "Paid"),
        RepaymentStatus.Due => ("bg-warning text-dark", "bi-clock", "Due"),
        RepaymentStatus.Missed => ("bg-danger", "bi-exclamation-triangle", "Missed"),
        RepaymentStatus.PaymentRequested => ("bg-info", "bi-send", "Payment Requested"),
        RepaymentStatus.DetailsSent => ("bg-primary", "bi-envelope-check", "Details Sent"),
        _ => ("bg-secondary", "bi-hourglass", "Upcoming")
    };

    var methodInfo = Model.PaymentMethodRequested switch
    {
        PaymentMethodType.USDT => ("bi-currency-exchange", "USDT (Tether)", "bg-success", "Provide the USDT wallet address and network (e.g., TRC-20, ERC-20) for the user to send payment."),
        PaymentMethodType.Bitcoin => ("bi-currency-bitcoin", "Bitcoin", "bg-warning text-dark", "Provide the Bitcoin wallet address for the user to send payment."),
        PaymentMethodType.BankTransfer => ("bi-bank", "Bank Transfer", "bg-primary", "Provide the bank name, account name, account number, and sort code."),
        _ => ("bi-dash", "Not Selected", "bg-secondary", "")
    };
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-1">
                <i class="bi bi-receipt text-primary me-2"></i>Installment #@Model.InstallmentNumber
            </h3>
            <p class="text-muted mb-0">
                @(Model.User?.FullName ?? "N/A") &bull;
                Due: @Model.DueDate.ToString("dd MMMM yyyy") &bull;
                <span class="badge @statusBadge.Item1"><i class="bi @statusBadge.Item2 me-1"></i>@statusBadge.Item3</span>
            </p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back to List
        </a>
    </div>

    @if (TempData["success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-1"></i> @TempData["success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle me-1"></i> @TempData["error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">
        <!-- Payment Info -->
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-info-circle me-2"></i>Installment Details</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-6">
                            <div class="text-muted small">Applicant</div>
                            <div class="fw-bold">@(Model.User?.FullName ?? "N/A")</div>
                        </div>
                        <div class="col-6">
                            <div class="text-muted small">Email</div>
                            <div class="fw-bold small">@(Model.User?.Email ?? "N/A")</div>
                        </div>
                        <div class="col-6">
                            <div class="text-muted small">Installment</div>
                            <div class="fw-bold">#@Model.InstallmentNumber of @Model.Loan?.DurationMonths</div>
                        </div>
                        <div class="col-6">
                            <div class="text-muted small">Due Date</div>
                            <div class="fw-bold">@Model.DueDate.ToString("dd MMM yyyy")</div>
                        </div>
                        <div class="col-4">
                            <div class="text-muted small">Principal</div>
                            <div class="fw-bold">$@Model.PrincipalPortion.ToString("N2")</div>
                        </div>
                        <div class="col-4">
                            <div class="text-muted small">Interest</div>
                            <div class="fw-bold">$@Model.InterestPortion.ToString("N2")</div>
                        </div>
                        <div class="col-4">
                            <div class="text-muted small">Total</div>
                            <div class="fw-bold text-primary fs-5">$@Model.Amount.ToString("N2")</div>
                        </div>
                    </div>

                    <hr />

                    <!-- Loan Summary -->
                    @if (Model.Loan != null)
                    {
                        <h6 class="fw-bold text-muted mb-2"><i class="bi bi-graph-up me-1"></i>Loan Summary</h6>
                        <div class="row g-2">
                            <div class="col-6">
                                <small class="text-muted">Principal</small>
                                <div class="fw-bold">$@Model.Loan.PrincipalAmount.ToString("N2")</div>
                            </div>
                            <div class="col-6">
                                <small class="text-muted">Interest Rate</small>
                                <div class="fw-bold">@Model.Loan.InterestRate%</div>
                            </div>
                            <div class="col-6">
                                <small class="text-muted">Duration</small>
                                <div class="fw-bold">@Model.Loan.DurationMonths months</div>
                            </div>
                            <div class="col-6">
                                <small class="text-muted">Started</small>
                                <div class="fw-bold">@Model.Loan.StartDate.ToString("dd MMM yyyy")</div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Admin Actions -->
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-gear me-2"></i>Admin Actions</h5>
                </div>
                <div class="card-body">
                    @if (Model.Status == RepaymentStatus.Paid)
                    {
                        <div class="text-center py-4">
                            <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
                            <h5 class="mt-3 text-success fw-bold">Payment Confirmed</h5>
                            <p class="text-muted">This installment has been marked as paid.</p>
                            @if (Model.PaidAt.HasValue)
                            {
                                <small class="text-muted">Confirmed on @Model.PaidAt.Value.ToString("dd MMM yyyy HH:mm")</small>
                            }
                            @if (!string.IsNullOrEmpty(Model.TransactionReference))
                            {
                                <div class="mt-2">
                                    <small class="text-muted">Transaction Ref:</small>
                                    <span class="badge bg-dark"><code class="text-white">@Model.TransactionReference</code></span>
                                </div>
                            }
                        </div>
                    }
                    else if (Model.Status == RepaymentStatus.Upcoming || Model.Status == RepaymentStatus.Due)
                    {
                        <div class="text-center py-4">
                            <i class="bi bi-hourglass text-secondary" style="font-size: 4rem;"></i>
                            <h5 class="mt-3 text-muted fw-bold">
                                @(Model.Status == RepaymentStatus.Due ? "Payment Due" : "Upcoming Payment")
                            </h5>
                            <p class="text-muted">Waiting for the user to request payment details.</p>
                        </div>
                    }
                    else if (Model.Status == RepaymentStatus.Missed)
                    {
                        <div class="alert alert-danger d-flex align-items-start mb-3">
                            <i class="bi bi-exclamation-triangle-fill me-2 fs-4"></i>
                            <div>
                                <strong>Missed Payment</strong>
                                <p class="mb-0 small">This payment was due on @Model.DueDate.ToString("dd MMM yyyy") and has not been paid. The user can still request payment details.</p>
                            </div>
                        </div>
                    }
                    else if (Model.Status == RepaymentStatus.PaymentRequested)
                    {
                        <!-- User has requested payment details — admin needs to send them -->
                        <div class="alert alert-info d-flex align-items-start mb-3">
                            <i class="bi bi-bell-fill me-2 fs-4"></i>
                            <div>
                                <strong>Action Required!</strong>
                                <p class="mb-0 small">
                                    The user has requested
                                    <span class="badge @methodInfo.Item3"><i class="bi @methodInfo.Item1 me-1"></i>@methodInfo.Item2</span>
                                    payment details.
                                </p>
                                @if (Model.PaymentRequestedAt.HasValue)
                                {
                                    <small class="text-muted d-block mt-1">Requested on @Model.PaymentRequestedAt.Value.ToString("dd MMM yyyy HH:mm")</small>
                                }
                            </div>
                        </div>

                        <form asp-action="SendPaymentDetails" method="post">
                            <input type="hidden" name="id" value="@Model.Id" />

                            @{
                                var wallets = ViewBag.CryptoWallets as List<LoanApp.Models.CryptoWallet>;
                            }

                            @if (wallets != null && wallets.Any())
                            {
                                <div class="mb-3">
                                    <label class="form-label fw-bold">
                                        <i class="bi bi-wallet2 me-1"></i>Select Wallet
                                    </label>
                                    <select name="walletId" class="form-select" id="walletSelect" required>
                                        <option value="">-- Select a wallet --</option>
                                        @foreach (var w in wallets)
                                        {
                                            var walletLabel = !string.IsNullOrEmpty(w.Label) ? w.Label : $"{w.WalletType} Wallet";
                                            var networkInfo = !string.IsNullOrEmpty(w.Network) ? $" ({w.Network})" : "";
                                            <option value="@w.Id"
                                                    data-address="@w.WalletAddress"
                                                    data-network="@w.Network"
                                                    data-label="@w.Label">
                                                @walletLabel@networkInfo — @w.WalletAddress[..Math.Min(20, w.WalletAddress.Length)]...
                                            </option>
                                        }
                                    </select>
                                    <div class="form-text">Select the wallet to send to the user.</div>
                                </div>

                                <!-- Wallet preview -->
                                <div id="walletPreview" class="card bg-light border-0 mb-3" style="display: none;">
                                    <div class="card-body py-2">
                                        <small class="text-muted">Selected Wallet Address:</small>
                                        <div class="fw-bold text-break" id="walletPreviewAddress"></div>
                                        <div class="text-muted small" id="walletPreviewNetwork"></div>
                                    </div>
                                </div>
                            }
                            else if (Model.PaymentMethodRequested == PaymentMethodType.USDT || Model.PaymentMethodRequested == PaymentMethodType.Bitcoin)
                            {
                                <div class="alert alert-warning mb-3">
                                    <i class="bi bi-exclamation-triangle me-1"></i>
                                    No active @Model.PaymentMethodRequested wallets configured.
                                    @if (User.IsInRole("GlobalAdmin"))
                                    {
                                        <a asp-area="Admin" asp-controller="CryptoWallet" asp-action="Create" class="alert-link">Add one now</a>
                                    }
                                    else
                                    {
                                        <span>Ask the Global Admin to add wallets.</span>
                                    }
                                </div>
                            }

                            @if (Model.PaymentMethodRequested == PaymentMethodType.BankTransfer)
                            {
                                <div class="mb-3">
                                    <label class="form-label fw-bold">
                                        <i class="bi @methodInfo.Item1 me-1"></i>@methodInfo.Item2 Payment Details
                                    </label>
                                    <textarea name="paymentDetails" class="form-control" rows="5"
                                              placeholder="@methodInfo.Item4"
                                              required></textarea>
                                    <div class="form-text">Enter the bank details that will be shown to the user.</div>
                                </div>
                            }
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="bi bi-send me-1"></i>Send Payment Details to User
                            </button>
                        </form>

                        @if (ViewBag.CryptoWallets is List<LoanApp.Models.CryptoWallet> scriptWallets && scriptWallets.Any())
                        {
                            <script>
                                document.getElementById('walletSelect')?.addEventListener('change', function() {
                                    var selected = this.options[this.selectedIndex];
                                    var preview = document.getElementById('walletPreview');
                                    if (this.value) {
                                        document.getElementById('walletPreviewAddress').textContent = selected.getAttribute('data-address');
                                        var network = selected.getAttribute('data-network');
                                        document.getElementById('walletPreviewNetwork').textContent = network ? 'Network: ' + network : '';
                                        preview.style.display = 'block';
                                    } else {
                                        preview.style.display = 'none';
                                    }
                                });
                            </script>
                        }
                    }
                    else if (Model.Status == RepaymentStatus.DetailsSent)
                    {
                        <div class="mb-3">
                            <div class="alert alert-primary d-flex align-items-start">
                                <i class="bi bi-envelope-check-fill me-2 fs-4"></i>
                                <div>
                                    <strong>Payment Details Sent</strong>
                                    <p class="mb-0 small">
                                        Waiting for user to make payment via
                                        <span class="badge @methodInfo.Item3"><i class="bi @methodInfo.Item1 me-1"></i>@methodInfo.Item2</span>
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="card bg-light border-0 mb-3">
                            <div class="card-body">
                                <h6 class="fw-bold mb-2"><i class="bi bi-key me-2"></i>Sent Payment Details</h6>
                                <div class="bg-white rounded p-3 border" style="white-space: pre-wrap; word-break: break-all;">@Model.PaymentDetails</div>
                                @if (Model.PaymentDetailsSentAt.HasValue)
                                {
                                    <small class="text-muted mt-2 d-block">Sent on @Model.PaymentDetailsSentAt.Value.ToString("dd MMM yyyy HH:mm")</small>
                                }
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(Model.TransactionReference))
                        {
                            <div class="card bg-light border-0 mb-3">
                                <div class="card-body">
                                    <h6 class="fw-bold mb-2"><i class="bi bi-receipt me-2"></i>User's Transaction Reference</h6>
                                    <div class="bg-white rounded p-3 border">
                                        <code>@Model.TransactionReference</code>
                                    </div>
                                </div>
                            </div>
                        }

                        <form asp-action="ConfirmPayment" method="post">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-success w-100"
                                    onclick="return confirm('Are you sure you want to confirm this payment as received?')">
                                <i class="bi bi-check2-circle me-1"></i>Confirm Payment Received
                            </button>
                        </form>
                    }

                    @if (User.IsInRole("GlobalAdmin"))
                    {
                        <hr class="my-3" />
                        <form asp-action="Delete" method="post">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-outline-danger w-100"
                                    onclick="return confirm('Are you sure you want to permanently delete this repayment record? This cannot be undone.')">
                                <i class="bi bi-trash3 me-1"></i>Delete Repayment
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Activity Timeline -->
    <div class="card border-0 shadow-sm mt-4">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0 fw-bold"><i class="bi bi-clock-history me-2"></i>Activity Timeline</h5>
        </div>
        <div class="card-body">
            <div class="timeline">
                <div class="timeline-item">
                    <div class="d-flex align-items-start">
                        <div class="timeline-icon bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width:36px; height:36px; min-width:36px;">
                            <i class="bi bi-calendar-plus"></i>
                        </div>
                        <div>
                            <div class="fw-bold">Installment Created</div>
                            <small class="text-muted">Due date: @Model.DueDate.ToString("dd MMM yyyy")</small>
                        </div>
                    </div>
                </div>

                @if (Model.PaymentRequestedAt.HasValue)
                {
                    <div class="timeline-item mt-3">
                        <div class="d-flex align-items-start">
                            <div class="timeline-icon bg-info text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width:36px; height:36px; min-width:36px;">
                                <i class="bi bi-send"></i>
                            </div>
                            <div>
                                <div class="fw-bold">User Requested @methodInfo.Item2 Payment</div>
                                <small class="text-muted">@Model.PaymentRequestedAt.Value.ToString("dd MMM yyyy HH:mm")</small>
                            </div>
                        </div>
                    </div>
                }

                @if (Model.PaymentDetailsSentAt.HasValue)
                {
                    <div class="timeline-item mt-3">
                        <div class="d-flex align-items-start">
                            <div class="timeline-icon bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width:36px; height:36px; min-width:36px;">
                                <i class="bi bi-envelope-check"></i>
                            </div>
                            <div>
                                <div class="fw-bold">Admin Sent Payment Details</div>
                                <small class="text-muted">@Model.PaymentDetailsSentAt.Value.ToString("dd MMM yyyy HH:mm")</small>
                            </div>
                        </div>
                    </div>
                }

                @if (!string.IsNullOrEmpty(Model.TransactionReference))
                {
                    <div class="timeline-item mt-3">
                        <div class="d-flex align-items-start">
                            <div class="timeline-icon bg-dark text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width:36px; height:36px; min-width:36px;">
                                <i class="bi bi-receipt"></i>
                            </div>
                            <div>
                                <div class="fw-bold">User Submitted Transaction Reference</div>
                                <small class="text-muted"><code>@Model.TransactionReference</code></small>
                            </div>
                        </div>
                    </div>
                }

                @if (Model.PaidAt.HasValue)
                {
                    <div class="timeline-item mt-3">
                        <div class="d-flex align-items-start">
                            <div class="timeline-icon bg-success text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width:36px; height:36px; min-width:36px;">
                                <i class="bi bi-check-circle"></i>
                            </div>
                            <div>
                                <div class="fw-bold">Payment Confirmed by Admin</div>
                                <small class="text-muted">@Model.PaidAt.Value.ToString("dd MMM yyyy HH:mm")</small>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
