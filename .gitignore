# =========================
# Build folders
# =========================
bin/
obj/
Debug/
Release/
publish/

# =========================
# User-specific files
# =========================
*.user
*.suo
*.userosscache
*.sln.docstates

# =========================
# Visual Studio & VS Code
# =========================
.vs/
.vscode/

# =========================
# NuGet packages
# =========================
*.nupkg
packages/
# Ignore the NuGet cache folder if you want
# ~/.nuget/packages

# =========================
# Logs and temporary files
# =========================
*.log
*.tmp
*.temp
*.pid
*.seed

# =========================
# OS generated files
# =========================
.DS_Store
Thumbs.db

# =========================
# Entity Framework / EF Core
# =========================
# Migrations are usually included, but ignore the compiled ones
**/Migrations/*.Designer.cs

# =========================
# Secret configuration
# =========================
appsettings.Development.json
secrets.json
appsettings.json
.env

# =========================
# Others (optional)
# =========================
# Ignore JetBrains Rider files if used
.idea/
*.sln.iml

# Ignore Rider caches
.idea/.idea.Workspace.xml