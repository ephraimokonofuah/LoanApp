@using Microsoft.AspNetCore.Identity
@using LoanApp.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject LoanApp.Repository.IRepository.IUnitOfWork UnitOfWork

@{
    var siteSettings = UnitOfWork.SiteSettings.Get(s => s.Id == 1);
    var siteName = siteSettings?.SiteName ?? "LoanApp";
    var isSignedIn = SignInManager.IsSignedIn(User);
    var isUser = isSignedIn && User.IsInRole("User");
    var isGlobalAdmin = isSignedIn && User.IsInRole("GlobalAdmin");
    var isAdmin = isSignedIn && (User.IsInRole("Admin") || isGlobalAdmin);
    var hasSidebar = isUser || isAdmin;

    // Active route detection
    var currentArea = ViewContext.RouteData.Values["area"]?.ToString() ?? "";
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    // Check approved eligibility for sidebar link
    int? sidebarEligibilityId = null;
    int userUnreadApplications = 0;
    int userUnreadEligibility = 0;
    int userUnreadDisbursements = 0;
    int userUnreadTickets = 0;
    int userUnreadRepayments = 0;
    if (isUser)
    {
        var currentUser = await UserManager.GetUserAsync(User);
        if (currentUser != null)
        {
            var approved = UnitOfWork.EligibilityCheck.Get(
                e => e.UserId == currentUser.Id && e.IsEligible && e.Status == "Approved");
            sidebarEligibilityId = approved?.Id;

            userUnreadApplications = UnitOfWork.LoanApplication
                .GetAll(a => a.UserId == currentUser.Id && !a.IsReadByUser).Count();
            userUnreadEligibility = UnitOfWork.EligibilityCheck
                .GetAll(e => e.UserId == currentUser.Id && !e.IsReadByUser).Count();
            userUnreadDisbursements = UnitOfWork.LoanDisbursement
                .GetAll(d => d.UserId == currentUser.Id && !d.IsReadByUser).Count();
            userUnreadTickets = UnitOfWork.SupportTicket
                .GetAll(t => t.UserId == currentUser.Id && !t.IsReadByUser).Count();
            userUnreadRepayments = UnitOfWork.Repayment
                .GetAll(r => r.UserId == currentUser.Id && !r.IsReadByUser).Count();
        }
    }

    int adminUnreadApplications = 0;
    int adminUnreadEligibility = 0;
    int adminUnreadDisbursements = 0;
    int adminUnreadTickets = 0;
    int adminUnreadRepayments = 0;
    if (isAdmin)
    {
        adminUnreadApplications = UnitOfWork.LoanApplication
            .GetAll(a => !a.IsReadByAdmin).Count();
        adminUnreadEligibility = UnitOfWork.EligibilityCheck
            .GetAll(e => !e.IsReadByAdmin).Count();
        adminUnreadDisbursements = UnitOfWork.LoanDisbursement
            .GetAll(d => !d.IsReadByAdmin).Count();
        adminUnreadTickets = UnitOfWork.SupportTicket
            .GetAll(t => !t.IsReadByAdmin).Count();
        adminUnreadRepayments = UnitOfWork.Repayment
            .GetAll(r => !r.IsReadByAdmin).Count();
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @siteName</title>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="~/favicon.png" />
    <link rel="icon" type="image/svg+xml" href="~/images/favicon.svg" />
    <link rel="apple-touch-icon" href="~/favicon.png" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LoanApp.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="//cdn.datatables.net/2.3.7/css/dataTables.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
</head>
<body>
    <!-- Top Navbar -->
    <nav class="navbar navbar-expand-sm navbar-dark bg-primary border-bottom shadow-sm fixed-top" style="z-index:1040;">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold d-flex align-items-center" asp-area="Client" asp-controller="Home" asp-action="Index">
                <img src="~/images/logo-icon.svg" alt="@siteName" width="32" height="32" class="me-2" />
                <span>@siteName</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#topNav"
                    aria-controls="topNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="topNav">
                @if (hasSidebar)
                {
                    <button class="btn btn-outline-light btn-sm d-none d-md-inline-flex me-3" id="sidebarToggle" type="button" title="Toggle sidebar">
                        <i class="bi bi-list"></i>
                    </button>
                }
                <ul class="navbar-nav ms-auto align-items-center">
                    <!-- Google Translate -->
                    <li class="nav-item d-flex align-items-center me-2">
                        <div id="google_translate_element"></div>
                    </li>
                    @if (isSignedIn)
                    {
                        var dropdownUser = await UserManager.GetUserAsync(User);
                        var dropdownLastName = dropdownUser?.FullName?.Split(' ').LastOrDefault() ?? UserManager.GetUserName(User);
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-person-circle me-1"></i>@dropdownLastName
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <a class="dropdown-item" asp-area="Identity" asp-page="/Account/Manage/Index">
                                        <i class="bi bi-gear me-2"></i>Account Settings
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <form id="logoutForm" asp-area="Identity" asp-page="/Account/Logout"
                                          asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "Client" })">
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="bi bi-box-arrow-right me-2"></i>Logout
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-area="Identity" asp-page="/Account/Login"><i class="bi bi-box-arrow-in-right me-1"></i>Login</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="Identity" asp-page="/Account/Register"><i class="bi bi-person-plus me-1"></i>Register</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="layout-wrapper" style="padding-top: 56px;">
        @if (hasSidebar)
        {
            <!-- Sidebar -->
            <aside class="sidebar bg-dark text-white" id="sidebar">
                <div class="sidebar-inner">
                    @if (isAdmin)
                    {
                        <div class="sidebar-header px-3 py-3 border-bottom border-secondary">
                            @if (isGlobalAdmin)
                            {
                                <span class="badge bg-warning text-dark px-2 py-1"><i class="bi bi-shield-fill-check me-1"></i>Global Admin</span>
                            }
                            else
                            {
                                <span class="badge bg-danger px-2 py-1"><i class="bi bi-shield-lock me-1"></i>Admin Panel</span>
                            }
                        </div>
                        <nav class="sidebar-nav">
                            <div class="sidebar-section-title">Dashboard</div>
                            <a class="sidebar-link @(currentArea == "Admin" && currentController == "LoanApplication" && currentAction == "Index" ? "active" : "")"
                               asp-area="Admin" asp-controller="LoanApplication" asp-action="Index">
                                <i class="bi bi-speedometer2"></i><span>Dashboard</span>
                            </a>

                            <div class="sidebar-section-title">Applications</div>
                            <a class="sidebar-link @(currentArea == "Admin" && currentController == "LoanApplication" && currentAction != "Index" ? "active" : "")"
                               asp-area="Admin" asp-controller="LoanApplication" asp-action="Index">
                                <i class="bi bi-file-earmark-text"></i><span>All Applications</span>
                                @if (adminUnreadApplications > 0)
                                {
                                    <span class="badge bg-danger rounded-pill ms-auto">@adminUnreadApplications</span>
                                }
                            </a>

                            <div class="sidebar-section-title">Eligibility</div>
                            <a class="sidebar-link @(currentArea == "Admin" && currentController == "Eligibility" ? "active" : "")"
                               asp-area="Admin" asp-controller="Eligibility" asp-action="Index">
                                <i class="bi bi-clipboard-check"></i><span>Eligibility Checks</span>
                                @if (adminUnreadEligibility > 0)
                                {
                                    <span class="badge bg-danger rounded-pill ms-auto">@adminUnreadEligibility</span>
                                }
                            </a>

                            <div class="sidebar-section-title">Configuration</div>
                            <a class="sidebar-link @(currentArea == "Admin" && currentController == "LoanType" ? "active" : "")"
                               asp-area="Admin" asp-controller="LoanType" asp-action="Index">
                                <i class="bi bi-tags"></i><span>Loan Types</span>
                            </a>
                            <a class="sidebar-link @(currentArea == "Admin" && currentController == "Bank" ? "active" : "")"
                               asp-area="Admin" asp-controller="Bank" asp-action="Index">
                                <i class="bi bi-bank2"></i><span>Banks</span>
                            </a>
                            @if (User.IsInRole("GlobalAdmin"))
                            {
                                <a class="sidebar-link @(currentArea == "Admin" && currentController == "CryptoWallet" ? "active" : "")"
                                   asp-area="Admin" asp-controller="CryptoWallet" asp-action="Index">
                                    <i class="bi bi-wallet2"></i><span>Crypto Wallets</span>
                                </a>
                            }

                            <div class="sidebar-section-title">Disbursements</div>
                            <a class="sidebar-link @(currentArea == "Admin" && currentController == "Disbursement" ? "active" : "")"
                               asp-area="Admin" asp-controller="Disbursement" asp-action="Index">
                                <i class="bi bi-cash-stack"></i><span>Disbursements</span>
                                @if (adminUnreadDisbursements > 0)
                                {
                                    <span class="badge bg-danger rounded-pill ms-auto">@adminUnreadDisbursements</span>
                                }
                            </a>

                            <div class="sidebar-section-title">Repayments</div>
                            <a class="sidebar-link @(currentArea == "Admin" && currentController == "Repayment" ? "active" : "")"
                               asp-area="Admin" asp-controller="Repayment" asp-action="Index">
                                <i class="bi bi-calendar2-check"></i><span>Repayments</span>
                                @if (adminUnreadRepayments > 0)
                                {
                                    <span class="badge bg-danger rounded-pill ms-auto">@adminUnreadRepayments</span>
                                }
                            </a>

                            <div class="sidebar-section-title">Support</div>
                            <a class="sidebar-link @(currentArea == "Admin" && currentController == "Support" ? "active" : "")"
                               asp-area="Admin" asp-controller="Support" asp-action="Index">
                                <i class="bi bi-headset"></i><span>Support Tickets</span>
                                @if (adminUnreadTickets > 0)
                                {
                                    <span class="badge bg-danger rounded-pill ms-auto">@adminUnreadTickets</span>
                                }
                            </a>

                            <div class="sidebar-section-title">Account</div>
                            <a class="sidebar-link @(currentArea == "Admin" && currentController == "User" ? "active" : "")"
                               asp-area="Admin" asp-controller="User" asp-action="Index">
                                <i class="bi bi-people"></i><span>User Management</span>
                            </a>
                            <a class="sidebar-link @(currentArea == "Admin" && currentController == "Settings" ? "active" : "")"
                               asp-area="Admin" asp-controller="Settings" asp-action="Index">
                                <i class="bi bi-gear"></i><span>Site Settings</span>
                            </a>
                            <a class="sidebar-link" asp-area="Identity" asp-page="/Account/Manage/Index">
                                <i class="bi bi-person-gear"></i><span>Profile Settings</span>
                            </a>
                        </nav>
                    }

                    @if (isUser)
                    {
                        <div class="sidebar-header px-3 py-3 border-bottom border-secondary">
                            <span class="badge bg-primary px-2 py-1"><i class="bi bi-person me-1"></i>My Account</span>
                        </div>
                        <nav class="sidebar-nav">
                            <div class="sidebar-section-title">Overview</div>
                            <a class="sidebar-link @(currentArea == "Client" && currentController == "Home" && currentAction == "Index" ? "active" : "")"
                               asp-area="Client" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house"></i><span>Home</span>
                            </a>

                            <div class="sidebar-section-title">Loans</div>
                            <a class="sidebar-link @(currentArea == "Client" && currentController == "LoanApplication" && currentAction == "Index" ? "active" : "")"
                               asp-area="Client" asp-controller="LoanApplication" asp-action="Index">
                                <i class="bi bi-folder2-open"></i><span>My Applications</span>
                                @if (userUnreadApplications > 0)
                                {
                                    <span class="badge bg-danger rounded-pill ms-auto">@userUnreadApplications</span>
                                }
                            </a>
                            <a class="sidebar-link @(currentArea == "Client" && currentController == "Disbursement" ? "active" : "")"
                               asp-area="Client" asp-controller="Disbursement" asp-action="Index">
                                <i class="bi bi-cash-stack"></i><span>My Disbursements</span>
                                @if (userUnreadDisbursements > 0)
                                {
                                    <span class="badge bg-danger rounded-pill ms-auto">@userUnreadDisbursements</span>
                                }
                            </a>
                            <a class="sidebar-link @(currentArea == "Client" && currentController == "Repayment" ? "active" : "")"
                               asp-area="Client" asp-controller="Repayment" asp-action="Index">
                                <i class="bi bi-calendar2-check"></i><span>My Repayments</span>
                                @if (userUnreadRepayments > 0)
                                {
                                    <span class="badge bg-danger rounded-pill ms-auto">@userUnreadRepayments</span>
                                }
                            </a>
                            @if (sidebarEligibilityId.HasValue)
                            {
                                <a class="sidebar-link @(currentArea == "Client" && currentController == "LoanApplication" && currentAction == "Create" ? "active" : "")"
                                   asp-area="Client" asp-controller="LoanApplication" asp-action="Create" asp-route-eligibilityId="@sidebarEligibilityId.Value">
                                    <i class="bi bi-file-earmark-plus"></i><span>Apply for Loan</span>
                                </a>
                            }
                            else
                            {
                                <a class="sidebar-link @(currentArea == "Client" && currentController == "Eligibility" && currentAction == "Check" ? "active" : "")"
                                   asp-area="Client" asp-controller="Eligibility" asp-action="Check">
                                    <i class="bi bi-clipboard-check"></i><span>Check Eligibility</span>
                                </a>
                            }

                            <div class="sidebar-section-title">Eligibility</div>
                            <a class="sidebar-link @(currentArea == "Client" && currentController == "Eligibility" && currentAction == "Check" ? "active" : "")"
                               asp-area="Client" asp-controller="Eligibility" asp-action="Check">
                                <i class="bi bi-clipboard-check"></i><span>Check Eligibility</span>
                            </a>
                            <a class="sidebar-link @(currentArea == "Client" && currentController == "Eligibility" && currentAction == "Index" ? "active" : "")"
                               asp-area="Client" asp-controller="Eligibility" asp-action="Index">
                                <i class="bi bi-list-check"></i><span>My Eligibility Checks</span>
                                @if (userUnreadEligibility > 0)
                                {
                                    <span class="badge bg-danger rounded-pill ms-auto">@userUnreadEligibility</span>
                                }
                            </a>

                            <div class="sidebar-section-title">Support</div>
                            <a class="sidebar-link @(currentArea == "Client" && currentController == "Support" ? "active" : "")"
                               asp-area="Client" asp-controller="Support" asp-action="Index">
                                <i class="bi bi-headset"></i><span>Support Tickets</span>
                                @if (userUnreadTickets > 0)
                                {
                                    <span class="badge bg-danger rounded-pill ms-auto">@userUnreadTickets</span>
                                }
                            </a>

                            <div class="sidebar-section-title">Account</div>
                            <a class="sidebar-link" asp-area="Identity" asp-page="/Account/Manage/Index">
                                <i class="bi bi-person-gear"></i><span>Profile Settings</span>
                            </a>
                            <a class="sidebar-link" asp-area="Client" asp-controller="Home" asp-action="Privacy">
                                <i class="bi bi-shield-check"></i><span>Privacy Policy</span>
                            </a>
                        </nav>
                    }
                </div>
            </aside>

            <!-- Sidebar overlay for mobile -->
            <div class="sidebar-overlay" id="sidebarOverlay"></div>
        }

        <!-- Main Content -->
        <main class="main-content @(hasSidebar ? "has-sidebar" : "")">
            <div class="container-fluid py-4 px-md-4">
                @RenderBody()
            </div>
        </main>
    </div>

    <footer class="main-footer @(hasSidebar ? "has-sidebar" : "")">
        <div class="footer-main bg-dark text-light pt-5 pb-4">
            <div class="container-fluid px-md-5">
                <div class="row g-4">
                    <!-- Company Info -->
                    <div class="col-lg-4 col-md-6">
                        <h5 class="fw-bold mb-3 text-white d-flex align-items-center">
                            <img src="~/images/logo-icon.svg" alt="@siteName" width="28" height="28" class="me-2" />
                            @siteName
                        </h5>
                        <p class="text-secondary small mb-3">
                            @(siteSettings?.FooterDescription ?? "Trusted lending solutions with competitive rates and transparent terms.")
                        </p>
                        <div class="d-flex gap-3 mt-3">
                            @if (!string.IsNullOrEmpty(siteSettings?.FacebookUrl))
                            {
                                <a href="@siteSettings.FacebookUrl" target="_blank" rel="noopener" class="text-secondary fs-5 footer-link" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
                            }
                            @if (!string.IsNullOrEmpty(siteSettings?.TwitterUrl))
                            {
                                <a href="@siteSettings.TwitterUrl" target="_blank" rel="noopener" class="text-secondary fs-5 footer-link" aria-label="Twitter"><i class="bi bi-twitter-x"></i></a>
                            }
                            @if (!string.IsNullOrEmpty(siteSettings?.LinkedInUrl))
                            {
                                <a href="@siteSettings.LinkedInUrl" target="_blank" rel="noopener" class="text-secondary fs-5 footer-link" aria-label="LinkedIn"><i class="bi bi-linkedin"></i></a>
                            }
                            @if (!string.IsNullOrEmpty(siteSettings?.InstagramUrl))
                            {
                                <a href="@siteSettings.InstagramUrl" target="_blank" rel="noopener" class="text-secondary fs-5 footer-link" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
                            }
                        </div>
                    </div>

                    <!-- Quick Links -->
                    <div class="col-lg-2 col-md-6">
                        <h6 class="fw-bold text-uppercase mb-3 small text-white">Quick Links</h6>
                        <ul class="list-unstyled small">
                            <li class="mb-2"><a asp-area="Client" asp-controller="Home" asp-action="Index" class="text-secondary text-decoration-none footer-link"><i class="bi bi-chevron-right me-1 small"></i>Home</a></li>
                            <li class="mb-2"><a asp-area="Client" asp-controller="Eligibility" asp-action="Check" class="text-secondary text-decoration-none footer-link"><i class="bi bi-chevron-right me-1 small"></i>Check Eligibility</a></li>
                            <li class="mb-2"><a asp-area="Client" asp-controller="LoanApplication" asp-action="Index" class="text-secondary text-decoration-none footer-link"><i class="bi bi-chevron-right me-1 small"></i>My Applications</a></li>
                            <li class="mb-2"><a asp-area="Client" asp-controller="Support" asp-action="Index" class="text-secondary text-decoration-none footer-link"><i class="bi bi-chevron-right me-1 small"></i>Support</a></li>
                        </ul>
                    </div>

                    <!-- Loan Products -->
                    <div class="col-lg-3 col-md-6">
                        <h6 class="fw-bold text-uppercase mb-3 small text-white">Loan Products</h6>
                        <ul class="list-unstyled small">
                            <li class="mb-2"><span class="text-secondary"><i class="bi bi-chevron-right me-1 small"></i>Personal Loans</span></li>
                            <li class="mb-2"><span class="text-secondary"><i class="bi bi-chevron-right me-1 small"></i>Business Loans</span></li>
                            <li class="mb-2"><span class="text-secondary"><i class="bi bi-chevron-right me-1 small"></i>Home Loans</span></li>
                            <li class="mb-2"><span class="text-secondary"><i class="bi bi-chevron-right me-1 small"></i>Education Loans</span></li>
                            <li class="mb-2"><span class="text-secondary"><i class="bi bi-chevron-right me-1 small"></i>Auto Loans</span></li>
                        </ul>
                    </div>

                    <!-- Contact Info -->
                    <div class="col-lg-3 col-md-6">
                        <h6 class="fw-bold text-uppercase mb-3 small text-white">Contact Us</h6>
                        <ul class="list-unstyled small">
                            <li class="mb-2 text-secondary">
                                <i class="bi bi-geo-alt-fill me-2"></i>@(siteSettings?.AddressLine1 ?? "123 Finance Street, Suite 400")<br>
                                <span class="ms-4">@(siteSettings?.AddressLine2 ?? "New York, NY 10001")</span>
                            </li>
                            <li class="mb-2 text-secondary">
                                <i class="bi bi-telephone-fill me-2"></i>@(siteSettings?.Phone ?? "(800) 555-LOAN")
                            </li>
                            <li class="mb-2 text-secondary">
                                <i class="bi bi-envelope-fill me-2"></i>@(siteSettings?.Email ?? "support@@loanapp.com")
                            </li>
                            <li class="mb-2 text-secondary">
                                <i class="bi bi-clock-fill me-2"></i>@(siteSettings?.BusinessHours ?? "Mon – Fri: 8AM – 6PM EST")
                            </li>
                        </ul>
                    </div>
                </div>

                <!-- Regulatory & Trust Badges -->
                <div class="border-top border-secondary mt-4 pt-3">
                    <div class="row align-items-center">
                        <div class="col-md-8">
                            <p class="text-secondary small mb-0">
                                <i class="bi bi-shield-lock-fill me-1"></i>
                                Your data is protected with 256-bit SSL encryption. All lending decisions are made in compliance
                                with federal and state lending regulations. NMLS #@(siteSettings?.NmlsNumber ?? "123456"). Equal Housing Lender.
                            </p>
                        </div>
                        <div class="col-md-4 text-md-end mt-2 mt-md-0">
                            <span class="badge bg-secondary me-1"><i class="bi bi-shield-check me-1"></i>SSL Secured</span>
                            <span class="badge bg-secondary me-1"><i class="bi bi-bank me-1"></i>FDIC</span>
                            <span class="badge bg-secondary"><i class="bi bi-house-check me-1"></i>Equal Housing</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bottom Bar -->
        <div class="bg-black text-center py-3">
            <div class="container-fluid px-md-5">
                <div class="row align-items-center">
                    <div class="col-md-6 text-md-start">
                        <span class="text-secondary small">&copy; @DateTime.Now.Year @siteName. All rights reserved.</span>
                    </div>
                    <div class="col-md-6 text-md-end mt-2 mt-md-0">
                        <a asp-area="Client" asp-controller="Home" asp-action="Privacy" class="text-secondary text-decoration-none small me-3 footer-link">Privacy Policy</a>
                        <a href="#" class="text-secondary text-decoration-none small me-3 footer-link">Terms of Service</a>
                        <a href="#" class="text-secondary text-decoration-none small footer-link">Disclosures</a>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="//cdn.datatables.net/2.3.7/js/dataTables.min.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <!-- Google Translate -->
    <script>
        function googleTranslateElementInit() {
            new google.translate.TranslateElement({
                pageLanguage: 'en',
                layout: google.translate.TranslateElement.InlineLayout.HORIZONTAL,
                autoDisplay: true,
                multilanguagePage: true
            }, 'google_translate_element');
        }
    </script>
